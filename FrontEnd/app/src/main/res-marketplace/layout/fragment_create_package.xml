<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_dark">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/surface_dark"
        app:navigationIcon="@drawable/ic_arrow_right"
        app:title="Crear Nuevo Paquete"
        app:titleTextAppearance="@style/TextAppearance.MaterialComponents.Headline6"
        app:titleTextColor="@color/text_primary_dark"
        app:navigationIconTint="@color/gold_primary"
        app:elevation="4dp" />

    <!-- ScrollView -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- NOMBRE SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INFORMACIÓN BÁSICA"
                android:textColor="@color/gold_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="16dp"
                android:layout_marginTop="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:boxBackgroundMode="outline"
                app:boxBackgroundColor="@color/surface_dark"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/divider_dark"
                app:boxStrokeWidth="1dp"
                app:hintTextColor="@color/gold_primary"
                app:counterEnabled="true"
                app:counterMaxLength="200">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary_dark"
                    android:textColorHint="@color/text_secondary_dark"
                    android:inputType="text"
                    android:hint="Ej: Rutinas de Fuerza"
                    android:textSize="14sp"
                    android:paddingVertical="14dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- DESCRIPCIÓN -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:boxBackgroundMode="outline"
                app:boxBackgroundColor="@color/surface_dark"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/divider_dark"
                app:boxStrokeWidth="1dp"
                app:hintTextColor="@color/gold_primary"
                app:counterEnabled="true"
                app:counterMaxLength="2000">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary_dark"
                    android:textColorHint="@color/text_secondary_dark"
                    android:inputType="textMultiLine"
                    android:hint="Descripción del paquete"
                    android:minLines="4"
                    android:maxLines="6"
                    android:textSize="14sp"
                    android:paddingVertical="12dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- TIPO Y CONFIGURACIÓN SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TIPO Y CONFIGURACIÓN"
                android:textColor="@color/gold_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="16dp"
                android:layout_marginTop="12dp" />

            <!-- TIPO DE PAQUETE -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                app:boxBackgroundColor="@color/surface_dark"
                app:boxStrokeColor="@color/divider_dark"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:hintTextColor="@color/gold_primary">

                <AutoCompleteTextView
                    android:id="@+id/spinner_package_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary_dark"
                    android:textColorHint="@color/text_secondary_dark"
                    android:inputType="none"
                    android:hint="Tipo de paquete"
                    android:textSize="14sp"
                    android:paddingVertical="14dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- SUSCRIPCIÓN REQUERIDA -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                app:boxBackgroundColor="@color/surface_dark"
                app:boxStrokeColor="@color/divider_dark"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:hintTextColor="@color/gold_primary">

                <AutoCompleteTextView
                    android:id="@+id/spinner_subscription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary_dark"
                    android:textColorHint="@color/text_secondary_dark"
                    android:inputType="none"
                    android:hint="Suscripción requerida"
                    android:textSize="14sp"
                    android:paddingVertical="14dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- PRECIO SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PRECIO"
                android:textColor="@color/gold_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"
                android:layout_marginTop="8dp" />

            <!-- Checkbox Gratis -->
            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cb_is_free"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Este paquete es gratuito"
                android:textColor="@color/text_primary_dark"
                android:buttonTint="@color/gold_primary"
                android:layout_marginBottom="12dp"
                android:textSize="14sp" />

            <!-- Precio y Moneda -->
            <LinearLayout
                android:id="@+id/layout_price"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_price"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="12dp"
                    app:boxBackgroundMode="outline"
                    app:boxBackgroundColor="@color/surface_dark"
                    app:boxStrokeColor="@color/divider_dark"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:hintTextColor="@color/gold_primary"
                    app:counterEnabled="true"
                    app:counterMaxLength="8">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_price"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary_dark"
                        android:textColorHint="@color/text_secondary_dark"
                        android:inputType="numberDecimal"
                        android:hint="Precio"
                        android:textSize="14sp"
                        android:paddingVertical="14dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    app:boxBackgroundMode="outline"
                    app:boxBackgroundColor="@color/surface_dark"
                    app:boxStrokeColor="@color/divider_dark"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:hintTextColor="@color/gold_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_currency"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary_dark"
                        android:textColorHint="@color/text_secondary_dark"
                        android:hint="USD"
                        android:text="USD"
                        android:textSize="14sp"
                        android:paddingVertical="14dp"
                        android:inputType="text" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- TAGS SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ETIQUETAS"
                android:textColor="@color/gold_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"
                android:layout_marginTop="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:boxBackgroundMode="outline"
                app:boxBackgroundColor="@color/surface_dark"
                app:boxStrokeColor="@color/divider_dark"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:hintTextColor="@color/gold_primary"
                app:helperTextEnabled="true"
                app:helperText="Separadas por comas. Ej: fuerza, hipertrofia">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_tags"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary_dark"
                    android:textColorHint="@color/text_secondary_dark"
                    android:hint="fuerza, hipertrofia, principiantes"
                    android:textSize="14sp"
                    android:paddingVertical="14dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Botón crear -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_create"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="CREAR PAQUETE"
                android:textColor="@color/background_dark"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                app:backgroundTint="@color/gold_primary"
                app:cornerRadius="12dp"
                app:elevation="4dp"
                android:layout_marginBottom="16dp" />

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:visibility="gone"
                android:indeterminateTint="@color/gold_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/adsd"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="CREAR PAQUETE"
                android:textColor="@color/background_dark"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                app:backgroundTint="@color/gold_primary"
                app:cornerRadius="12dp"
                app:elevation="4dp"
                android:layout_marginBottom="16dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>