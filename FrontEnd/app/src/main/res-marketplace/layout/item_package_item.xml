<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="#252525"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="#333333"
    app:strokeWidth="0.5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Orden -->
        <TextView
            android:id="@+id/tv_display_order"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="#1"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#121212"
            android:background="@drawable/badge_package_order" />

        <!-- Contenido -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tv_content_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre Contenido"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_content_detail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detalles"
                android:textSize="12sp"
                android:textColor="#B3B3B3"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tv_notes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sin notas"
                android:textSize="11sp"
                android:textColor="#78703F"
                android:fontFamily="monospace"
                android:layout_marginTop="4dp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Tipo badge -->
        <TextView
            android:id="@+id/tv_item_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ROUTINE"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="6dp"
            android:paddingVertical="3dp"
            android:background="@drawable/badge_item_type"
            android:layout_marginStart="12dp" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>