<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ── RIBBON SUPERIOR estilo Word ────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="0dp"
            app:cardElevation="4dp"
            app:strokeColor="#2A2A2A"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="8dp">

                <!-- Fila 1: Nombre de rutina + cronómetro -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:id="@+id/tv_routine_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Entrenamiento"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <!-- Cronómetro -->
                    <LinearLayout
                        android:id="@+id/layout_timer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_badge_rounded"
                        android:backgroundTint="#78703F"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp">

                        <TextView
                            android:id="@+id/tv_timer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00:00"
                            android:textColor="#121212"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Fila 2: Acciones rápidas (ribbon) -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Acción: Expandir todo -->
                        <LinearLayout
                            android:id="@+id/btn_expand_all"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp"
                            android:minWidth="60dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackgroundBorderless">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/arrow_down"
                                app:tint="#78703F" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Expandir"
                                android:textColor="#B3B3B3"
                                android:textSize="9sp"
                                android:layout_marginTop="3dp" />

                        </LinearLayout>

                        <!-- Separador -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="32dp"
                            android:background="#2A2A2A"
                            android:layout_marginHorizontal="4dp" />

                        <!-- Acción: Colapsar todo -->
                        <LinearLayout
                            android:id="@+id/btn_collapse_all"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp"
                            android:minWidth="60dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackgroundBorderless">

                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:src="@drawable/arrow_up"
                                app:tint="#78703F" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Colapsar"
                                android:textColor="#B3B3B3"
                                android:textSize="9sp"
                                android:layout_marginTop="3dp" />

                        </LinearLayout>

                        <!-- Separador -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="32dp"
                            android:background="#2A2A2A"
                            android:layout_marginHorizontal="4dp" />


                        <!-- Separador -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="32dp"
                            android:background="#2A2A2A"
                            android:layout_marginHorizontal="4dp" />

                        <!-- Acción: Historial (visual) -->
                        <LinearLayout
                            android:id="@+id/btn_history"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp"
                            android:minWidth="60dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackgroundBorderless">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_auto_mode"
                                app:tint="#78703F" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Automatico"
                                android:textColor="#B3B3B3"
                                android:textSize="9sp"
                                android:layout_marginTop="3dp" />

                        </LinearLayout>

                        <!-- Separador -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="32dp"
                            android:background="#2A2A2A"
                            android:layout_marginHorizontal="4dp" />

                        <LinearLayout
                            android:id="@+id/btn_rest_settings"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp"
                            android:minWidth="60dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackgroundBorderless">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_settings_24"
                                app:tint="#78703F" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ajustes"
                                android:textColor="#B3B3B3"
                                android:textSize="9sp"
                                android:layout_marginTop="3dp" />

                        </LinearLayout>

                    </LinearLayout>

                </HorizontalScrollView>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingTop="8dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="100dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="true" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="@color/gold_primary"
        android:visibility="gone" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_save_workout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="80dp"
        android:src="@android:drawable/ic_menu_save"
        android:contentDescription="Guardar entrenamiento"
        app:backgroundTint="@color/gold_primary"
        app:tint="@color/background_dark"
        app:elevation="8dp"
        android:visibility="invisible" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>