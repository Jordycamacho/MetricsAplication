<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_set_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="@color/surface_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Franja de color del tipo de set -->
        <View
            android:id="@+id/view_type_stripe"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="@color/set_type_normal"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="10dp">

            <!-- ── HEADER: checkbox + resumen tipo + badge ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <!-- ⭐ CHECKBOX DE COMPLETADO -->
                <CheckBox
                    android:id="@+id/checkbox_set_completed"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginEnd="12dp"
                    android:button="@drawable/checkbox_selector"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Marcar como completado"/>

                <TextView
                    android:id="@+id/tv_param_summary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="REPS · KG"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary_dark"
                    android:textAllCaps="true"
                    android:letterSpacing="0.10"/>

                <TextView
                    android:id="@+id/tv_set_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NORMAL"
                    android:textSize="9sp"
                    android:textColor="@color/background_dark"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:paddingHorizontal="9dp"
                    android:paddingVertical="4dp"
                    android:background="@drawable/bg_badge_rounded"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_controls_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:id="@+id/layout_reps_container"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_reps_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="REPS"
                        android:textSize="9sp"
                        android:textColor="@color/text_secondary_dark"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="6dp"/>

                    <ImageButton
                        android:id="@+id/btn_increase_reps"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/arrow_up"
                        android:background="@drawable/bg_circle_button_gold_filled"
                        android:contentDescription="+"
                        android:layout_marginBottom="2dp"
                        app:tint="@color/background_dark"/>

                    <TextView
                        android:id="@+id/tv_reps_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10"
                        android:textSize="38sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary_dark"
                        android:gravity="center"
                        android:minWidth="56dp"
                        android:paddingVertical="2dp"/>

                    <ImageButton
                        android:id="@+id/btn_decrease_reps"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/arrow_down"
                        android:background="@drawable/bg_circle_button_outline"
                        android:contentDescription="-"
                        android:layout_marginTop="2dp"
                        app:tint="@color/gold_primary"/>

                </LinearLayout>

                <View
                    android:id="@+id/view_divider"
                    android:layout_width="1dp"
                    android:layout_height="100dp"
                    android:background="#2A2A2A"
                    android:layout_marginHorizontal="12dp"/>

                <LinearLayout
                    android:id="@+id/layout_param_container"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_weight_unit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KG"
                        android:textSize="9sp"
                        android:textColor="@color/text_secondary_dark"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="6dp"/>

                    <ImageButton
                        android:id="@+id/btn_increase_weight"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/arrow_up"
                        android:background="@drawable/bg_circle_button_gold_filled"
                        android:contentDescription="+"
                        android:layout_marginBottom="2dp"
                        app:tint="@color/background_dark"/>

                    <TextView
                        android:id="@+id/tv_weight_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="38sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary_dark"
                        android:gravity="center"
                        android:minWidth="56dp"
                        android:paddingVertical="2dp"/>

                    <ImageButton
                        android:id="@+id/btn_decrease_weight"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/arrow_down"
                        android:background="@drawable/bg_circle_button_outline"
                        android:contentDescription="-"
                        android:layout_marginTop="2dp"
                        app:tint="@color/gold_primary"/>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_duration_extra"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="14dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_duration_label_extra"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TIEMPO"
                    android:textSize="9sp"
                    android:textColor="@color/text_secondary_dark"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="6dp"/>

                <ImageButton
                    android:id="@+id/btn_increase_duration_extra"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_add"
                    android:background="@drawable/bg_circle_button_gold_filled"
                    android:contentDescription="+5s"
                    android:layout_marginBottom="2dp"
                    app:tint="@color/background_dark"/>

                <!-- Tap para iniciar/parar -->
                <TextView
                    android:id="@+id/tv_duration_timer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1m 00s"
                    android:textSize="38sp"
                    android:textStyle="bold"
                    android:textColor="@color/gold_primary"
                    android:gravity="center"
                    android:minWidth="56dp"
                    android:paddingVertical="2dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

                <ImageButton
                    android:id="@+id/btn_decrease_duration_extra"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_remove"
                    android:background="@drawable/bg_circle_button_outline"
                    android:contentDescription="-5s"
                    android:layout_marginTop="2dp"
                    app:tint="@color/gold_primary"/>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1E1E1E"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:id="@+id/layout_rest_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_badge_warning"
                android:paddingHorizontal="12dp"
                android:paddingVertical="9dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tv_rest_timer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="60s descanso"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_rest_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TAP"
                    android:textSize="9sp"
                    android:textColor="#C8B560"
                    android:textAllCaps="true"
                    android:letterSpacing="0.10"
                    android:alpha="0.7"/>

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>