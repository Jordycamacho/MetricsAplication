<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_set_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/surface_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Franja de color del tipo de set -->
        <View
            android:id="@+id/view_type_stripe"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="@color/set_type_normal" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="10dp">

            <!-- ── HEADER ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tv_param_summary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="REPS · KG"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary_dark"
                    android:textAllCaps="true"
                    android:letterSpacing="0.10" />

                <TextView
                    android:id="@+id/tv_set_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NORMAL"
                    android:textSize="9sp"
                    android:textColor="@color/background_dark"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:paddingHorizontal="9dp"
                    android:paddingVertical="4dp"
                    android:background="@drawable/bg_badge_rounded" />

            </LinearLayout>

            <!-- ══ FILA DE PICKERS ══ -->
            <LinearLayout
                android:id="@+id/layout_controls_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="14dp">

                <!-- ── COLUMNA IZQUIERDA: REPS / TIEMPO ── -->
                <LinearLayout
                    android:id="@+id/layout_reps_container"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tv_reps_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="REPS"
                        android:textSize="9sp"
                        android:textColor="@color/text_secondary_dark"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="6dp" />

                    <!-- Contenedor para picker y contador -->
                    <FrameLayout
                        android:layout_width="80dp"
                        android:layout_height="120dp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp">

                        <!-- Picker frame con fade top/bottom -->
                        <FrameLayout
                            android:id="@+id/frame_reps_picker"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/picker_reps"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:overScrollMode="never"
                                android:scrollbars="none"
                                android:nestedScrollingEnabled="false" />

                            <!-- Fade top -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="40dp"
                                android:layout_gravity="top"
                                android:background="@drawable/bg_fade_top_surface"
                                android:clickable="false"
                                android:focusable="false" />

                            <!-- Líneas de selección -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_gravity="center_vertical"
                                android:layout_marginBottom="20dp"
                                android:background="#2A2A2A"
                                android:clickable="false"
                                android:focusable="false" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_gravity="center_vertical"
                                android:layout_marginTop="20dp"
                                android:background="#2A2A2A"
                                android:clickable="false"
                                android:focusable="false" />

                            <!-- Fade bottom -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="40dp"
                                android:layout_gravity="bottom"
                                android:background="@drawable/bg_fade_bottom_surface"
                                android:clickable="false"
                                android:focusable="false" />

                        </FrameLayout>

                        <!-- ⭐ NUEVO: Contador de duración (oculto inicialmente) -->
                        <FrameLayout
                            android:id="@+id/frame_duration_counter"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="gone">

                            <TextView
                                android:id="@+id/tv_duration_counter"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="3:45"
                                android:textSize="32sp"
                                android:textColor="@color/gold_primary"
                                android:gravity="center"
                                android:textStyle="bold" />

                        </FrameLayout>

                    </FrameLayout>

                    <LinearLayout
                        android:id="@+id/layout_duration_play"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_duration_play_button"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:layout_marginTop="8dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="▶ INICIAR"
                            android:textSize="13sp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btn_start_duration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TAP"
                            android:textSize="9sp"
                            android:textColor="#C8B560"
                            android:textAllCaps="true"
                            android:letterSpacing="0.10"
                            android:alpha="0.8" />

                    </LinearLayout>

                </LinearLayout>

                <!-- DIVISOR VERTICAL -->
                <View
                    android:id="@+id/view_divider"
                    android:layout_width="1dp"
                    android:layout_height="100dp"
                    android:background="#2A2A2A"
                    android:layout_marginHorizontal="12dp"
                    android:visibility="gone" />

                <!-- ── COLUMNA DERECHA: PARAM / TIEMPO ── -->
                <LinearLayout
                    android:id="@+id/layout_param_container"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tv_weight_unit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KG"
                        android:textSize="9sp"
                        android:textColor="@color/text_secondary_dark"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="6dp" />

                    <!-- Contenedor para picker y contador -->
                    <FrameLayout
                        android:layout_width="80dp"
                        android:layout_height="120dp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp">

                        <FrameLayout
                            android:id="@+id/frame_param_picker"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/picker_param"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:overScrollMode="never"
                                android:scrollbars="none"
                                android:nestedScrollingEnabled="false" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="40dp"
                                android:layout_gravity="top"
                                android:background="@drawable/bg_fade_top_surface"
                                android:clickable="false"
                                android:focusable="false" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_gravity="center_vertical"
                                android:layout_marginBottom="20dp"
                                android:background="#2A2A2A"
                                android:clickable="false"
                                android:focusable="false" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_gravity="center_vertical"
                                android:layout_marginTop="20dp"
                                android:background="#2A2A2A"
                                android:clickable="false"
                                android:focusable="false" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="40dp"
                                android:layout_gravity="bottom"
                                android:background="@drawable/bg_fade_bottom_surface"
                                android:clickable="false"
                                android:focusable="false" />

                        </FrameLayout>

                    </FrameLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- ── BLOQUE DURACIÓN EXTRA (3 parámetros) ── -->
            <LinearLayout
                android:id="@+id/layout_duration_extra"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="14dp"
                android:visibility="gone">

                <!-- MINUTOS -->
                <LinearLayout
                    android:id="@+id/layout_duration_minutes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MIN"
                        android:textSize="9sp"
                        android:textColor="@color/text_secondary_dark"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="6dp" />

                    <!-- Contenedor para picker y contador -->
                    <FrameLayout
                        android:layout_width="80dp"
                        android:layout_height="120dp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp">

                        <FrameLayout
                            android:id="@+id/frame_minutes_picker"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/picker_duration_minutes"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:overScrollMode="never"
                                android:scrollbars="none"
                                android:nestedScrollingEnabled="false" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="40dp"
                                android:layout_gravity="top"
                                android:background="@drawable/bg_fade_top_surface"
                                android:clickable="false"
                                android:focusable="false" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_gravity="center_vertical"
                                android:layout_marginBottom="20dp"
                                android:background="#2A2A2A"
                                android:clickable="false"
                                android:focusable="false" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_gravity="center_vertical"
                                android:layout_marginTop="20dp"
                                android:background="#2A2A2A"
                                android:clickable="false"
                                android:focusable="false" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="40dp"
                                android:layout_gravity="bottom"
                                android:background="@drawable/bg_fade_bottom_surface"
                                android:clickable="false"
                                android:focusable="false" />

                        </FrameLayout>

                        <!-- ⭐ NUEVO: Contador en duración extra minutos -->
                        <FrameLayout
                            android:id="@+id/frame_duration_counter_minutes"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="gone">

                            <TextView
                                android:id="@+id/tv_duration_counter_minutes"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="3:45"
                                android:textSize="32sp"
                                android:textColor="@color/gold_primary"
                                android:gravity="center"
                                android:textStyle="bold" />

                        </FrameLayout>

                    </FrameLayout>

                    <!-- ⭐ NUEVO: Botón play minutos con MISMA estética del timer de set -->
                    <LinearLayout
                        android:id="@+id/layout_duration_play_minutes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_duration_play_button"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:layout_marginTop="8dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="▶ INICIAR"
                            android:textSize="13sp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btn_start_duration_minutes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TAP"
                            android:textSize="9sp"
                            android:textColor="#C8B560"
                            android:textAllCaps="true"
                            android:letterSpacing="0.10"
                            android:alpha="0.8" />

                    </LinearLayout>

                </LinearLayout>

                <!-- DIVISOR -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="100dp"
                    android:background="#2A2A2A"
                    android:layout_marginHorizontal="12dp" />

                <!-- SEGUNDOS -->
                <LinearLayout
                    android:id="@+id/layout_duration_seconds"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SEG"
                        android:textSize="9sp"
                        android:textColor="@color/text_secondary_dark"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="6dp" />

                    <!-- Contenedor para picker y contador -->
                    <FrameLayout
                        android:layout_width="80dp"
                        android:layout_height="120dp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp">

                        <FrameLayout
                            android:id="@+id/frame_seconds_picker"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/picker_duration_seconds"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:overScrollMode="never"
                                android:scrollbars="none"
                                android:nestedScrollingEnabled="false" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="40dp"
                                android:layout_gravity="top"
                                android:background="@drawable/bg_fade_top_surface"
                                android:clickable="false"
                                android:focusable="false" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_gravity="center_vertical"
                                android:layout_marginBottom="20dp"
                                android:background="#2A2A2A"
                                android:clickable="false"
                                android:focusable="false" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_gravity="center_vertical"
                                android:layout_marginTop="20dp"
                                android:background="#2A2A2A"
                                android:clickable="false"
                                android:focusable="false" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="40dp"
                                android:layout_gravity="bottom"
                                android:background="@drawable/bg_fade_bottom_surface"
                                android:clickable="false"
                                android:focusable="false" />

                        </FrameLayout>

                        <!-- ⭐ NUEVO: Contador en duración extra segundos -->
                        <FrameLayout
                            android:id="@+id/frame_duration_counter_seconds"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="gone">

                            <TextView
                                android:id="@+id/tv_duration_counter_seconds"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="3:45"
                                android:textSize="32sp"
                                android:textColor="@color/gold_primary"
                                android:gravity="center"
                                android:textStyle="bold" />

                        </FrameLayout>

                    </FrameLayout>

                    <!-- ⭐ NUEVO: Botón play segundos con MISMA estética del timer de set -->
                    <LinearLayout
                        android:id="@+id/layout_duration_play_seconds"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_duration_play_button"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:layout_marginTop="8dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="▶ INICIAR"
                            android:textSize="13sp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btn_start_duration_seconds"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TAP"
                            android:textSize="9sp"
                            android:textColor="#C8B560"
                            android:textAllCaps="true"
                            android:letterSpacing="0.10"
                            android:alpha="0.8" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>



            <!-- ── TIMER DE DESCANSO ── -->
            <LinearLayout
                android:id="@+id/layout_rest_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_badge_warning"
                android:paddingHorizontal="12dp"
                android:paddingVertical="9dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tv_rest_timer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="60s descanso"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_rest_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TAP"
                    android:textSize="9sp"
                    android:textColor="#C8B560"
                    android:textAllCaps="true"
                    android:letterSpacing="0.10"
                    android:alpha="0.8" />

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>