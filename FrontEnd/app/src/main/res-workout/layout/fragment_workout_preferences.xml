<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#1E1E1E"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="#78703F"
            app:title="Configuración de entrenamiento"
            app:titleTextColor="#FFFFFF" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#78703F"
            android:alpha="0.4" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="40dp">

                <!-- Sección vibración -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="VIBRACIÓN"
                    android:textColor="#78703F"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardBackgroundColor="#1E1E1E"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#333333"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Vibración al terminar descanso"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="El dispositivo vibrará cuando acabe el tiempo"
                                android:textColor="#B3B3B3"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switch_vibration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textOn=""
                            android:textOff=""
                            android:showText="false"
                            app:thumbTint="#78703F"
                            app:trackTint="#3A3A3A" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Sección sonido -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SONIDO"
                    android:textColor="#78703F"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardBackgroundColor="#1E1E1E"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#333333"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sonido al terminar descanso"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ideal para usar con auriculares"
                                android:textColor="#B3B3B3"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switch_sound"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textOn=""
                            android:textOff=""
                            android:showText="false"
                            app:thumbTint="#78703F"
                            app:trackTint="#3A3A3A" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Volumen de timers -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="VOLUMEN"
                    android:textColor="#78703F"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp"
                    android:layout_marginTop="4dp" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_timer_volume"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardBackgroundColor="#1E1E1E"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#333333"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Volumen de timers"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_volume_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="70%"
                                android:textColor="#78703F"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <com.google.android.material.slider.Slider
                            android:id="@+id/slider_timer_volume"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:valueFrom="0"
                            android:valueTo="100"
                            android:stepSize="5" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Sonidos por tipo de timer -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SONIDOS POR TIPO"
                    android:textColor="#78703F"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_timer_sounds"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardBackgroundColor="#1E1E1E"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#333333"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp">

                        <!-- DESCANSO DE SET -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⏱ Descanso de Set"
                            android:textColor="#78703F"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="10dp"
                            android:layout_marginTop="6dp" />

                        <RadioGroup
                            android:id="@+id/rg_set_rest_sound"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <RadioButton
                                android:id="@+id/rb_set_rest_beep"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Beep — pitido doble"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:buttonTint="#78703F"
                                android:paddingVertical="4dp" />

                            <RadioButton
                                android:id="@+id/rb_set_rest_bell"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Bell — campana"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:buttonTint="#78703F"
                                android:paddingVertical="4dp" />

                            <RadioButton
                                android:id="@+id/rb_set_rest_chime"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Chime — tono suave"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:buttonTint="#78703F"
                                android:paddingVertical="4dp" />

                            <RadioButton
                                android:id="@+id/rb_set_rest_buzz"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Buzz — zumbido"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:buttonTint="#78703F"
                                android:paddingVertical="4dp" />

                            <RadioButton
                                android:id="@+id/rb_set_rest_ping"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Ping — sonido agudo"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:buttonTint="#78703F"
                                android:paddingVertical="4dp" />

                        </RadioGroup>

                        <!-- SEPARATOR -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#333333"
                            android:layout_marginVertical="12dp"
                            android:alpha="0.5" />

                        <!-- DESCANSO DE EJERCICIO -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Descanso de Ejercicio"
                            android:textColor="#78703F"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="10dp"
                            android:layout_marginTop="6dp" />

                        <RadioGroup
                            android:id="@+id/rg_exercise_rest_sound"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <RadioButton
                                android:id="@+id/rb_exercise_rest_beep"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Beep — pitido doble"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:buttonTint="#78703F"
                                android:paddingVertical="4dp" />

                            <RadioButton
                                android:id="@+id/rb_exercise_rest_bell"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Bell — campana"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:buttonTint="#78703F"
                                android:paddingVertical="4dp" />

                            <RadioButton
                                android:id="@+id/rb_exercise_rest_chime"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Chime — tono suave"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:buttonTint="#78703F"
                                android:paddingVertical="4dp" />

                            <RadioButton
                                android:id="@+id/rb_exercise_rest_buzz"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Buzz — zumbido"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:buttonTint="#78703F"
                                android:paddingVertical="4dp" />

                            <RadioButton
                                android:id="@+id/rb_exercise_rest_ping"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Ping — sonido agudo"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:buttonTint="#78703F"
                                android:paddingVertical="4dp" />

                        </RadioGroup>

                        <!-- SEPARATOR -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#333333"
                            android:layout_marginVertical="12dp"
                            android:alpha="0.5" />

                        <!-- DURACIÓN COMPLETADA -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Duración Completada"
                            android:textColor="#78703F"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="10dp"
                            android:layout_marginTop="6dp" />

                        <RadioGroup
                            android:id="@+id/rg_duration_complete_sound"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <RadioButton
                                android:id="@+id/rb_duration_beep"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Beep — pitido doble"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:buttonTint="#78703F"
                                android:paddingVertical="4dp" />

                            <RadioButton
                                android:id="@+id/rb_duration_bell"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Bell — campana"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:buttonTint="#78703F"
                                android:paddingVertical="4dp" />

                            <RadioButton
                                android:id="@+id/rb_duration_chime"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Chime — tono suave"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:buttonTint="#78703F"
                                android:paddingVertical="4dp" />

                            <RadioButton
                                android:id="@+id/rb_duration_buzz"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Buzz — zumbido"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:buttonTint="#78703F"
                                android:paddingVertical="4dp" />

                            <RadioButton
                                android:id="@+id/rb_duration_ping"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Ping — sonido agudo"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:buttonTint="#78703F"
                                android:paddingVertical="4dp" />

                        </RadioGroup>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ⭐ NUEVA SECCIÓN: Vista de sets -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="VISTA DE SETS"
                    android:textColor="#78703F"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardBackgroundColor="#1E1E1E"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#333333"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Estilo de visualización"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp" />

                        <RadioGroup
                            android:id="@+id/rg_set_view_type"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <RadioButton
                                android:id="@+id/rb_view_classic"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Clásica — botones tradicionales"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:buttonTint="#78703F"
                                android:paddingVertical="6dp" />

                            <RadioButton
                                android:id="@+id/rb_view_modern"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Moderna — botón circular flotante"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:buttonTint="#78703F"
                                android:paddingVertical="6dp" />

                        </RadioGroup>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Nota informativa -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#0D78703F"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#78703F"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ℹ"
                            android:textColor="#78703F"
                            android:textSize="16sp"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Los avisos funcionan aunque la app esté en segundo plano. El sonido se reproduce por auriculares si están conectados."
                            android:textColor="#B3B3B3"
                            android:textSize="12sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>