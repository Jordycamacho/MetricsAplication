<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="4dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/card_exercise"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@color/card_dark"
        android:clickable="true"
        android:focusable="true"
        android:longClickable="true"
        android:foreground="?attr/selectableItemBackground">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Franja izquierda: dorada por defecto, cambia con agrupación -->
            <View
                android:id="@+id/view_group_stripe"
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="@color/gold_primary"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Fila 1: checkbox + nombre + badge progreso + flecha -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- CHECKBOX CIRCULAR DEL EJERCICIO -->
                    <androidx.appcompat.widget.AppCompatCheckBox
                        android:id="@+id/checkbox_exercise_completed"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginEnd="10dp"
                        android:button="@drawable/checkbox_selector"
                        android:background="@null"
                        android:buttonTint="@null"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:padding="0dp"
                        android:scaleX="1"
                        android:scaleY="1"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:contentDescription="Marcar día completado"/>

                    <TextView
                        android:id="@+id/tv_exercise_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Press Banca"
                        android:textColor="@color/text_primary_dark"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <!-- CONTADOR DE SETS DINÁMICO -->
                    <TextView
                        android:id="@+id/tv_sets_progress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0/3"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary_dark"
                        android:layout_marginEnd="8dp"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="3dp"
                        android:background="@drawable/bg_badge_rounded"
                        android:backgroundTint="#2A2A2A"/>

                    <ImageView
                        android:id="@+id/iv_expand"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_arrow_down"
                        app:tint="@color/gold_primary"/>

                </LinearLayout>

                <!-- Fila 2: badges de modo especial + agrupación (sólo visibles si aplica) -->
                <LinearLayout
                    android:id="@+id/layout_exercise_badges"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp"
                    android:visibility="gone">

                    <!-- Badge: modo especial (AMRAP / EMOM / TABATA) -->
                    <TextView
                        android:id="@+id/tv_special_mode_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AMRAP"
                        android:textSize="9sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:paddingHorizontal="9dp"
                        android:paddingVertical="4dp"
                        android:background="@drawable/bg_badge_rounded"
                        android:backgroundTint="#1565C0"
                        android:layout_marginEnd="6dp"
                        android:visibility="gone"/>

                    <!-- Badge: agrupación (CIRCUITO / SUPERSET) -->
                    <TextView
                        android:id="@+id/tv_group_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CIRCUITO"
                        android:textSize="9sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:paddingHorizontal="9dp"
                        android:paddingVertical="4dp"
                        android:background="@drawable/bg_badge_rounded"
                        android:backgroundTint="#00695C"
                        android:layout_marginEnd="6dp"
                        android:visibility="gone"/>

                    <!-- Badge: nota presente -->
                    <TextView
                        android:id="@+id/tv_notes_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📝"
                        android:textSize="12sp"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="3dp"
                        android:background="@drawable/bg_badge_rounded"
                        android:backgroundTint="#2A2A2A"
                        android:visibility="gone"/>

                </LinearLayout>

                <!-- Fila 3: info del modo especial (parámetros numéricos) -->
                <TextView
                    android:id="@+id/tv_special_mode_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textSize="11sp"
                    android:textColor="#78703F"
                    android:letterSpacing="0.04"
                    android:visibility="gone"/>

            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Contenedor de sets -->
    <LinearLayout
        android:id="@+id/layout_sets_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="4dp"
        android:paddingTop="4dp"
        android:visibility="gone">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_sets"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"/>

        <!-- ── DESCANSO DEL EJERCICIO ── -->
        <LinearLayout
            android:id="@+id/layout_exercise_rest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_exercise_rest_block"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:layout_marginTop="6dp"
            android:layout_marginStart="8dp"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DESCANSO"
                    android:textSize="8sp"
                    android:textColor="@color/gold_primary"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="2dp"/>

                <TextView
                    android:id="@+id/tv_exercise_rest"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="90s"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary_dark"/>

            </LinearLayout>

            <TextView
                android:id="@+id/tv_exercise_rest_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TAP"
                android:textSize="9sp"
                android:textColor="@color/gold_primary"
                android:textAllCaps="true"
                android:letterSpacing="0.10"
                android:alpha="0.7"/>

        </LinearLayout>

    </LinearLayout>
</LinearLayout>