<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:background="@drawable/bg_card_dark"
    android:layout_marginBottom="4dp"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/tv_set_number"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:text="Set 1"
        android:textColor="@color/gold_primary"
        android:textStyle="bold"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tv_set_details"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="10 reps × 80kg"
        android:textColor="@color/text_primary_dark"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tv_set_volume"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="800 kg"
        android:textColor="@color/text_secondary_dark"
        android:textSize="12sp"
        android:paddingEnd="8dp" />

    <TextView
        android:id="@+id/tv_set_pr"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🏆"
        android:textSize="16sp"
        android:visibility="gone" />

</LinearLayout>