<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Estado CHECKED: círculo relleno con checkmark dorado -->
    <item android:state_checked="true">
        <layer-list>
            <item>
                <shape android:shape="oval">
                    <solid android:color="#78703F"/>
                    <stroke android:color="#78703F" android:width="2dp"/>
                </shape>
            </item>
            <!-- Checkmark blanco -->
            <item
                android:gravity="center"
                android:drawable="@drawable/ic_checkbox_check_white"
                android:width="16dp"
                android:height="16dp"/>
        </layer-list>
    </item>

    <item android:state_checked="false">
        <shape android:shape="oval">
            <solid android:color="#121212"/>
            <stroke android:color="#78703F" android:width="2dp"/>
        </shape>
    </item>

</selector>