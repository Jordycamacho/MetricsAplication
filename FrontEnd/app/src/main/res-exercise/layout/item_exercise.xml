<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/card_dark"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#2A2A2A"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Línea 1: Nombre + badge tipo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tv_exercise_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nombre del ejercicio"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary_dark"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_exercise_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TIPO"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#121212"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:background="@drawable/badge_predefined"
                android:letterSpacing="0.05" />
        </LinearLayout>

        <!-- Línea 2: Deportes -->
        <TextView
            android:id="@+id/tv_exercise_sports"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Deportes: —"
            android:textSize="13sp"
            android:textColor="@color/gold_primary"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginBottom="6dp" />

        <!-- Línea 3: Métricas en fila horizontal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_exercise_usage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 usos"
                android:textSize="12sp"
                android:textColor="@color/text_secondary_dark"
                android:visibility="gone" />

            <View
                android:id="@+id/divider_1"
                android:layout_width="1dp"
                android:layout_height="12dp"
                android:background="@color/divider_dark"
                android:layout_marginHorizontal="8dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_exercise_rating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sin calificación"
                android:textSize="12sp"
                android:textColor="@color/text_secondary_dark"
                android:visibility="gone" />

            <View
                android:id="@+id/divider_2"
                android:layout_width="1dp"
                android:layout_height="12dp"
                android:background="@color/divider_dark"
                android:layout_marginHorizontal="8dp" />

            <TextView
                android:id="@+id/tv_exercise_visibility"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Personal"
                android:textSize="12sp"
                android:textColor="@color/text_secondary_dark" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>