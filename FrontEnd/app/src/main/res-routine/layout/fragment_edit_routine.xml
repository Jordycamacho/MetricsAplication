<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#1E1E1E"
        app:navigationIcon="@drawable/ic_arrow_right"
        app:titleTextColor="#FFFFFF"
        app:title="Editar Rutina"
        app:navigationIconTint="#78703F" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#78703F"
        android:alpha="0.4" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="32dp">

            <!-- Header info mejorado (V2) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1A78703F"
                android:padding="14dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="36dp"
                        android:background="#78703F"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rutina Personal"
                            android:textColor="#78703F"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:id="@+id/tv_routine_info"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="..."
                            android:textColor="#B3B3B3"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Información V2 adicional -->
                <TextView
                    android:id="@+id/tv_export_key"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#B3B3B3"
                    android:textSize="11sp"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_times_purchased"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#B3B3B3"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_original_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#B3B3B3"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Nombre -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NOMBRE"
                android:textColor="#78703F"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:boxBackgroundMode="outline"
                app:boxBackgroundColor="#1E1E1E"
                app:boxCornerRadiusTopStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusBottomEnd="10dp"
                app:hintTextColor="#B3B3B3"
                app:boxStrokeColor="#333333"
                app:boxStrokeWidth="1dp"
                android:hint="Nombre de la rutina">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_routine_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:inputType="textCapSentences"
                    android:paddingVertical="14dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Deporte -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DEPORTE"
                android:textColor="#78703F"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                app:boxBackgroundColor="#1E1E1E"
                app:boxCornerRadiusTopStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusBottomEnd="10dp"
                app:hintTextColor="#B3B3B3"
                app:boxStrokeColor="#333333"
                app:boxStrokeWidth="1dp"
                android:hint="Sin deporte específico">

                <AutoCompleteTextView
                    android:id="@+id/spinner_sports"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:inputType="none"
                    android:focusable="true"
                    android:focusableInTouchMode="false"
                    android:paddingVertical="14dp"
                    android:paddingHorizontal="14dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Objetivo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OBJETIVO"
                android:textColor="#78703F"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:boxBackgroundMode="outline"
                app:boxBackgroundColor="#1E1E1E"
                app:boxCornerRadiusTopStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusBottomEnd="10dp"
                app:hintTextColor="#B3B3B3"
                app:boxStrokeColor="#333333"
                app:boxStrokeWidth="1dp"
                android:hint="Ej: Ganar masa muscular">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_goal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:inputType="textCapSentences"
                    android:paddingVertical="14dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Contenedor para Días específicos (solo se muestra si la rutina usa días) -->
            <LinearLayout
                android:id="@+id/layout_days_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DÍAS DE ENTRENAMIENTO"
                    android:textColor="#78703F"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="#1E1E1E"
                    android:padding="12dp"
                    android:layout_marginBottom="20dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="L" android:textColor="#B3B3B3" android:textSize="12sp"
                            android:textStyle="bold" android:layout_marginBottom="4dp"/>
                        <CheckBox android:id="@+id/cb_monday" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:buttonTint="#78703F" android:gravity="center"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="M" android:textColor="#B3B3B3" android:textSize="12sp"
                            android:textStyle="bold" android:layout_marginBottom="4dp"/>
                        <CheckBox android:id="@+id/cb_tuesday" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:buttonTint="#78703F" android:gravity="center"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="X" android:textColor="#B3B3B3" android:textSize="12sp"
                            android:textStyle="bold" android:layout_marginBottom="4dp"/>
                        <CheckBox android:id="@+id/cb_wednesday" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:buttonTint="#78703F" android:gravity="center"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="J" android:textColor="#B3B3B3" android:textSize="12sp"
                            android:textStyle="bold" android:layout_marginBottom="4dp"/>
                        <CheckBox android:id="@+id/cb_thursday" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:buttonTint="#78703F" android:gravity="center"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="V" android:textColor="#B3B3B3" android:textSize="12sp"
                            android:textStyle="bold" android:layout_marginBottom="4dp"/>
                        <CheckBox android:id="@+id/cb_friday" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:buttonTint="#78703F" android:gravity="center"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="S" android:textColor="#B3B3B3" android:textSize="12sp"
                            android:textStyle="bold" android:layout_marginBottom="4dp"/>
                        <CheckBox android:id="@+id/cb_saturday" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:buttonTint="#78703F" android:gravity="center"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="D" android:textColor="#B3B3B3" android:textSize="12sp"
                            android:textStyle="bold" android:layout_marginBottom="4dp"/>
                        <CheckBox android:id="@+id/cb_sunday" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:buttonTint="#78703F" android:gravity="center"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Contenedor para Sesiones por semana (solo se muestra si la rutina usa sesiones) -->
            <LinearLayout
                android:id="@+id/layout_sessions_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SESIONES POR SEMANA"
                    android:textColor="#78703F"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:boxBackgroundMode="outline"
                    app:boxBackgroundColor="#1E1E1E"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:hintTextColor="#B3B3B3"
                    app:boxStrokeColor="#333333"
                    app:boxStrokeWidth="1dp"
                    android:hint="Número de sesiones (1-7)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_sessions_per_week"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:inputType="number"
                        android:maxLength="1"
                        android:paddingVertical="14dp" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Versión (con validación semántica) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VERSIÓN (formato semántico: 1.2.3)"
                android:textColor="#78703F"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"
                android:layout_marginTop="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_version"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:boxBackgroundMode="outline"
                app:boxBackgroundColor="#1E1E1E"
                app:boxCornerRadiusTopStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusBottomEnd="10dp"
                app:hintTextColor="#B3B3B3"
                app:boxStrokeColor="#333333"
                app:boxStrokeWidth="1dp"
                android:hint="Ej: 1.0.0, 2.1, 3">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_version"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:inputType="text"
                    android:paddingVertical="14dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Botones -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_routine"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="GUARDAR CAMBIOS"
                android:textColor="#121212"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                app:backgroundTint="#78703F"
                app:cornerRadius="12dp"
                android:elevation="0dp"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_toggle_active"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="DESACTIVAR RUTINA"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                app:backgroundTint="#1AE41D1D"
                app:strokeColor="#E41D1D"
                app:strokeWidth="1dp"
                app:cornerRadius="12dp"
                android:elevation="0dp"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete_routine"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="ELIMINAR RUTINA"
                android:textColor="#E41D1D"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                app:backgroundTint="#00000000"
                app:strokeColor="#E41D1D"
                app:strokeWidth="1dp"
                app:cornerRadius="12dp"
                android:elevation="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/sdaas"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="ELIMINAR RUTINA"
                android:textColor="#E41D1D"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                app:backgroundTint="#00000000"
                app:strokeColor="#E41D1D"
                app:strokeWidth="1dp"
                app:cornerRadius="12dp"
                android:elevation="0dp" />

            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                android:indeterminateTint="#78703F" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>