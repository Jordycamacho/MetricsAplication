<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#1E1E1E"
        app:navigationIcon="@drawable/ic_arrow_right"
        app:titleTextColor="#FFFFFF"
        app:title="Nueva Rutina"
        app:navigationIconTint="#78703F" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#78703F"
        android:alpha="0.4" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="32dp">

            <!-- Header info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1A78703F"
                android:padding="14dp"
                android:layout_marginBottom="24dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="36dp"
                    android:background="#78703F"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rutina Personal"
                        android:textColor="#78703F"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Solo visible para ti"
                        android:textColor="#B3B3B3"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Nombre -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NOMBRE"
                android:textColor="#78703F"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:boxBackgroundMode="outline"
                app:boxBackgroundColor="#1E1E1E"
                app:boxCornerRadiusTopStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusBottomEnd="10dp"
                app:hintTextColor="#B3B3B3"
                app:boxStrokeColor="#333333"
                app:boxStrokeWidth="1dp"
                android:hint="Ej: Rutina de fuerza">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_routine_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:inputType="textCapSentences"
                    android:paddingVertical="14dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Deporte -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DEPORTE"
                android:textColor="#78703F"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                app:boxBackgroundColor="#1E1E1E"
                app:boxCornerRadiusTopStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusBottomEnd="10dp"
                app:hintTextColor="#B3B3B3"
                app:boxStrokeColor="#333333"
                app:boxStrokeWidth="1dp"
                android:hint="Sin deporte específico">

                <AutoCompleteTextView
                    android:id="@+id/spinner_sports"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:inputType="none"
                    android:focusable="true"
                    android:focusableInTouchMode="false"
                    android:paddingVertical="14dp"
                    android:paddingHorizontal="14dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Objetivo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OBJETIVO"
                android:textColor="#78703F"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:boxBackgroundMode="outline"
                app:boxBackgroundColor="#1E1E1E"
                app:boxCornerRadiusTopStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusBottomEnd="10dp"
                app:hintTextColor="#B3B3B3"
                app:boxStrokeColor="#333333"
                app:boxStrokeWidth="1dp"
                android:hint="Ej: Ganar masa muscular">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_goal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:inputType="textCapSentences"
                    android:paddingVertical="14dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Sesiones por semana -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SESIONES POR SEMANA"
                android:textColor="#78703F"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:boxBackgroundMode="outline"
                app:boxBackgroundColor="#1E1E1E"
                app:boxCornerRadiusTopStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusBottomEnd="10dp"
                app:hintTextColor="#B3B3B3"
                app:boxStrokeColor="#333333"
                app:boxStrokeWidth="1dp"
                android:hint="3">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_sessions_per_week"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:inputType="number"
                    android:paddingVertical="14dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Días de entrenamiento -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DÍAS DE ENTRENAMIENTO"
                android:textColor="#78703F"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#1E1E1E"
                android:padding="12dp"
                android:layout_marginBottom="32dp">

                <!-- L -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="L" android:textColor="#B3B3B3" android:textSize="12sp"
                        android:textStyle="bold" android:layout_marginBottom="4dp"/>
                    <CheckBox android:id="@+id/cb_monday" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:buttonTint="#78703F" android:gravity="center"/>
                </LinearLayout>
                <!-- M -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="M" android:textColor="#B3B3B3" android:textSize="12sp"
                        android:textStyle="bold" android:layout_marginBottom="4dp"/>
                    <CheckBox android:id="@+id/cb_tuesday" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:buttonTint="#78703F" android:gravity="center"/>
                </LinearLayout>
                <!-- X -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="X" android:textColor="#B3B3B3" android:textSize="12sp"
                        android:textStyle="bold" android:layout_marginBottom="4dp"/>
                    <CheckBox android:id="@+id/cb_wednesday" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:buttonTint="#78703F" android:gravity="center"/>
                </LinearLayout>
                <!-- J -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="J" android:textColor="#B3B3B3" android:textSize="12sp"
                        android:textStyle="bold" android:layout_marginBottom="4dp"/>
                    <CheckBox android:id="@+id/cb_thursday" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:buttonTint="#78703F" android:gravity="center"/>
                </LinearLayout>
                <!-- V -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="V" android:textColor="#B3B3B3" android:textSize="12sp"
                        android:textStyle="bold" android:layout_marginBottom="4dp"/>
                    <CheckBox android:id="@+id/cb_friday" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:buttonTint="#78703F" android:gravity="center"/>
                </LinearLayout>
                <!-- S -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="S" android:textColor="#B3B3B3" android:textSize="12sp"
                        android:textStyle="bold" android:layout_marginBottom="4dp"/>
                    <CheckBox android:id="@+id/cb_saturday" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:buttonTint="#78703F" android:gravity="center"/>
                </LinearLayout>
                <!-- D -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="D" android:textColor="#B3B3B3" android:textSize="12sp"
                        android:textStyle="bold" android:layout_marginBottom="4dp"/>
                    <CheckBox android:id="@+id/cb_sunday" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:buttonTint="#78703F" android:gravity="center"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Botón crear -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_create_routine"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="CREAR RUTINA"
                android:textColor="#121212"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                app:backgroundTint="#78703F"
                app:cornerRadius="12dp"
                android:elevation="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/bdwdwn_create_routine"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="CREAR RUTINA"
                android:textColor="#121212"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                app:backgroundTint="#78703F"
                app:cornerRadius="12dp"
                android:elevation="0dp" />

            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                android:indeterminateTint="#78703F" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>