<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="#1E1E1E"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#2A2A2A"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_routine_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nombre"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <TextView
                    android:id="@+id/tv_version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="11sp"
                    android:textColor="#B3B3B3"
                    android:layout_marginStart="6dp"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_last_used"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hoy"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#121212"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:background="@drawable/badge_predefined"
                android:layout_marginStart="10dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Deporte -->
        <TextView
            android:id="@+id/tv_sport_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Deporte"
            android:textSize="12sp"
            android:textColor="#78703F"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"
            android:visibility="gone" />

        <!-- Ejercicios count -->
        <TextView
            android:id="@+id/tv_exercise_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 ejercicios"
            android:textSize="12sp"
            android:textColor="#B3B3B3"
            android:layout_marginBottom="12dp" />

        <!-- Separador -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#252525"
            android:layout_marginBottom="12dp" />

        <!-- Botones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_start_workout"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Iniciar"
                android:textColor="#121212"
                android:textSize="13sp"
                android:textStyle="bold"
                app:backgroundTint="#78703F"
                app:cornerRadius="10dp"
                android:elevation="0dp"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_edit"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Editar"
                android:textColor="#78703F"
                android:textSize="13sp"
                app:strokeColor="#78703F"
                app:strokeWidth="1dp"
                app:cornerRadius="10dp"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_exercises"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="+"
                android:textColor="#78703F"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingHorizontal="0dp"
                app:strokeColor="#78703F"
                app:strokeWidth="1dp"
                app:cornerRadius="10dp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>