<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0A">

    <!-- ══ HERO ══ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.4">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_login_hero" />

        <View
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="center"
            android:layout_marginTop="-40dp"
            android:background="@drawable/bg_circle_gold_faint" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="JNOBFIT"
                android:textColor="#C8B560"
                android:textSize="36sp"
                android:textStyle="bold"
                android:letterSpacing="0.28"
                android:includeFontPadding="false" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp">

                <View
                    android:layout_width="24dp"
                    android:layout_height="1dp"
                    android:background="#C8B560"
                    android:alpha="0.5" />

                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_diamond_gold"
                    android:layout_marginHorizontal="8dp" />

                <View
                    android:layout_width="24dp"
                    android:layout_height="1dp"
                    android:background="#C8B560"
                    android:alpha="0.5" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Crea tu cuenta y empieza hoy"
                android:textColor="#888888"
                android:textSize="13sp"
                android:letterSpacing="0.04" />

        </LinearLayout>

    </FrameLayout>

    <!-- ══ PANEL FORMULARIO ══ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        android:overScrollMode="never"
        android:fillViewport="false"
        android:background="@drawable/bg_form_panel">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="32dp"
            android:paddingBottom="40dp">

            <!-- Título sección -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Crear cuenta"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:letterSpacing="0.01"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Comienza tu entrenamiento"
                android:textColor="#555555"
                android:textSize="13sp"
                android:layout_marginBottom="28dp" />

            <!-- ── NOMBRE ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NOMBRE COMPLETO"
                android:textColor="#C8B560"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.14"
                android:layout_marginBottom="7dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_full_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:boxBackgroundMode="outline"
                app:boxBackgroundColor="#131313"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="#272727"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="1.5dp"
                app:hintEnabled="false"
                app:errorEnabled="true"
                app:counterEnabled="true"
                app:counterMaxLength="50"
                app:startIconDrawable="@drawable/ic_profile"
                app:startIconTint="#444444">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_full_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:hint="Tu nombre completo"
                    android:textColorHint="#3A3A3A"
                    android:inputType="textPersonName|textCapWords"
                    android:maxLength="50"
                    android:paddingVertical="15dp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── EMAIL ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CORREO"
                android:textColor="#C8B560"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.14"
                android:layout_marginBottom="7dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:boxBackgroundMode="outline"
                app:boxBackgroundColor="#131313"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="#272727"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="1.5dp"
                app:hintEnabled="false"
                app:errorEnabled="true"
                app:startIconDrawable="@drawable/ic_email"
                app:startIconTint="#444444">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:hint="correo@ejemplo.com"
                    android:textColorHint="#3A3A3A"
                    android:inputType="textEmailAddress"
                    android:paddingVertical="15dp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── CONTRASEÑA ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONTRASEÑA"
                android:textColor="#C8B560"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.14"
                android:layout_marginBottom="7dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:boxBackgroundMode="outline"
                app:boxBackgroundColor="#131313"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="#272727"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="1.5dp"
                app:hintEnabled="false"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="#555555"
                app:errorEnabled="true"
                app:helperText="Usa letras y números para mayor seguridad"
                app:helperTextTextColor="#3A3A3A"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="#444444">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:hint="Mínimo 6 caracteres"
                    android:textColorHint="#3A3A3A"
                    android:inputType="textPassword"
                    android:paddingVertical="15dp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── CONFIRMAR CONTRASEÑA ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONFIRMAR CONTRASEÑA"
                android:textColor="#C8B560"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.14"
                android:layout_marginBottom="7dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_confirm_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:boxBackgroundMode="outline"
                app:boxBackgroundColor="#131313"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="#272727"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="1.5dp"
                app:hintEnabled="false"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="#555555"
                app:errorEnabled="true"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="#444444">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_confirm_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:hint="Repite tu contraseña"
                    android:textColorHint="#3A3A3A"
                    android:inputType="textPassword"
                    android:paddingVertical="15dp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── BOTÓN CREAR CUENTA ── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_register"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="CREAR CUENTA"
                android:textColor="#0A0A0A"
                android:textSize="13.5sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                app:backgroundTint="#C8B560"
                app:cornerRadius="14dp"
                android:elevation="0dp"
                android:layout_marginBottom="20dp" />

            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:visibility="gone"
                android:indeterminateTint="#C8B560" />

            <!-- ── LINK LOGIN ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¿Ya tienes cuenta? "
                    android:textColor="#444444"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_login"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Inicia sesión"
                    android:textColor="#C8B560"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:padding="4dp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>