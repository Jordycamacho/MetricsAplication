<?xml version="1.0" encoding="utf-8"?>
<!-- Uso: el Fragment asigna los valores vía binding después del include -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <!-- Ícono izquierdo -->
    <ImageView
        android:id="@+id/iv_row_icon"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:src="@drawable/ic_profile"
        app:tint="@color/gold_primary" />

    <!-- Textos -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="14dp">

        <TextView
            android:id="@+id/tv_row_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Título"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_row_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#666666"
            android:textSize="11sp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Badge opcional (ej: "No verificado") -->
    <TextView
        android:id="@+id/tv_row_badge"
        android:layout_width="wrap_content"
        android:layout_height="20dp"
        android:paddingHorizontal="8dp"
        android:textSize="10sp"
        android:textStyle="bold"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_badge_warning" />

    <!-- Chevron -->
    <ImageView
        android:id="@+id/iv_row_chevron"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/ic_chevron_right"
        app:tint="#444444" />

</LinearLayout>