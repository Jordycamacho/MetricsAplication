<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface_dark"
    android:paddingHorizontal="24dp"
    android:paddingTop="24dp"
    android:paddingBottom="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Unidades de medida"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Solo afecta la visualización. Los valores guardados no cambian."
        android:textColor="#666666"
        android:textSize="12sp"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PESO"
        android:textColor="@color/gold_primary"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/rg_weight_unit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="20dp">

        <RadioButton
            android:id="@+id/rb_weight_kg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kilogramos (kg)"
            android:textColor="#FFFFFF"
            android:buttonTint="@color/gold_primary" />

        <RadioButton
            android:id="@+id/rb_weight_lbs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Libras (lbs)"
            android:textColor="#FFFFFF"
            android:buttonTint="@color/gold_primary" />
    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DISTANCIA"
        android:textColor="@color/gold_primary"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/rg_distance_unit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/rb_distance_m"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Metros (m)"
            android:textColor="#FFFFFF"
            android:buttonTint="@color/gold_primary" />

        <RadioButton
            android:id="@+id/rb_distance_ft"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pies (ft)"
            android:textColor="#FFFFFF"
            android:buttonTint="@color/gold_primary" />
    </RadioGroup>

</LinearLayout>
