<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface_dark"
    android:paddingHorizontal="24dp"
    android:paddingTop="24dp"
    android:paddingBottom="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Acerca de JNOBFIT"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tv_about_version"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="JNOBFIT v1.0"
        android:textColor="@color/gold_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="App de entrenamiento en beta. Los ajustes se guardan en este dispositivo."
        android:textColor="#B3B3B3"
        android:textSize="13sp"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tv_about_website"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="jnobfit.online"
        android:textColor="@color/gold_primary"
        android:textSize="13sp"
        android:paddingVertical="8dp" />

</LinearLayout>
