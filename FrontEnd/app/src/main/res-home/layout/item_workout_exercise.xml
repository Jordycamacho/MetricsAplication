<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="4dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/card_exercise"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@color/card_dark"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Franja dorada izquierda -->
            <View
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="@color/gold_primary"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_exercise_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Press Banca"
                    android:textColor="@color/text_primary_dark"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <ImageView
                    android:id="@+id/iv_expand"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_down"
                    android:layout_marginStart="12dp"
                    app:tint="@color/gold_primary"/>

            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Contenedor de sets -->
    <LinearLayout
        android:id="@+id/layout_sets_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="4dp"
        android:paddingTop="4dp"
        android:visibility="gone">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_sets"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"/>

        <!-- ── DESCANSO DEL EJERCICIO ── siempre visible si restAfterExercise > 0
             Fondo negro, borde dorado — estilo premium diferenciado del set -->
        <LinearLayout
            android:id="@+id/layout_exercise_rest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_exercise_rest_block"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:layout_marginTop="6dp"
            android:layout_marginStart="8dp"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DESCANSO"
                    android:textSize="8sp"
                    android:textColor="@color/gold_primary"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="2dp"/>

                <TextView
                    android:id="@+id/tv_exercise_rest"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="90s"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary_dark"/>

            </LinearLayout>

            <TextView
                android:id="@+id/tv_exercise_rest_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TAP"
                android:textSize="9sp"
                android:textColor="@color/gold_primary"
                android:textAllCaps="true"
                android:letterSpacing="0.10"
                android:alpha="0.7"/>

        </LinearLayout>

    </LinearLayout>
</LinearLayout>