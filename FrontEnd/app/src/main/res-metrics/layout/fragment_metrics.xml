<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <!-- Header -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_dark"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingHorizontal="8dp"
            app:title="Métricas"
            app:titleTextColor="#FFFFFF" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!-- Hero: Estadísticas generales -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="32dp"
                android:paddingHorizontal="24dp">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_metrics"
                    app:tint="@color/gold_primary"
                    android:alpha="0.8" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Métricas y Progreso"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Analiza tu rendimiento y evolución"
                    android:textColor="@color/text_secondary_dark"
                    android:textSize="13sp"
                    android:gravity="center" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1E1E1E"
                android:layout_marginHorizontal="16dp" />

            <!-- Section: Disponible ahora -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DISPONIBLE AHORA"
                android:textColor="@color/gold_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp" />

            <!-- Card: Historial de entrenamientos (CLICKEABLE) -->
            <LinearLayout
                android:id="@+id/card_workout_history"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_card_dark"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_training"
                    android:background="@drawable/shape_circle_gold_outline"
                    android:padding="10dp"
                    app:tint="@color/gold_primary" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Historial de entrenamientos"
                        android:textColor="#EEEEEE"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Revisa todas tus sesiones completadas"
                        android:textColor="#888888"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.3" />

                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="@color/gold_primary"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1E1E1E"
                android:layout_marginHorizontal="16dp" />

            <!-- Próximamente -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PRÓXIMAMENTE"
                android:textColor="@color/gold_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginStart="20dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp" />

            <!-- Card: Progreso de fuerza -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_card_dark"
                android:padding="16dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_training"
                    android:background="@drawable/shape_circle_gold_outline"
                    android:padding="10dp"
                    app:tint="@color/gold_primary"
                    android:alpha="0.6" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Progreso de fuerza"
                        android:textColor="#CCCCCC"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Evolución de peso por ejercicio a lo largo del tiempo"
                        android:textColor="#555555"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.3" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="20dp"
                    android:paddingHorizontal="8dp"
                    android:text="PRONTO"
                    android:textColor="#121212"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/bg_badge_gold"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Card: Volumen semanal -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_card_dark"
                android:padding="16dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_metrics"
                    android:background="@drawable/shape_circle_gold_outline"
                    android:padding="10dp"
                    app:tint="@color/gold_primary"
                    android:alpha="0.6" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Volumen semanal"
                        android:textColor="#CCCCCC"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Series, repeticiones y carga total por semana"
                        android:textColor="#555555"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.3" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="20dp"
                    android:paddingHorizontal="8dp"
                    android:text="PRONTO"
                    android:textColor="#121212"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/bg_badge_gold"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Card: Récords personales -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_card_dark"
                android:padding="16dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_crown"
                    android:background="@drawable/shape_circle_gold_outline"
                    android:padding="10dp"
                    app:tint="@color/gold_primary"
                    android:alpha="0.6" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Récords personales"
                        android:textColor="#CCCCCC"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Tus mejores marcas históricas por ejercicio"
                        android:textColor="#555555"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.3" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="20dp"
                    android:paddingHorizontal="8dp"
                    android:text="PRONTO"
                    android:textColor="#121212"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/bg_badge_gold"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Card: Consistencia -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_card_dark"
                android:padding="16dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_dashboard_black_24dp"
                    android:background="@drawable/shape_circle_gold_outline"
                    android:padding="10dp"
                    app:tint="@color/gold_primary"
                    android:alpha="0.6" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Consistencia y rachas"
                        android:textColor="#CCCCCC"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Días entrenados, rachas activas y hábito semanal"
                        android:textColor="#555555"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.3" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="20dp"
                    android:paddingHorizontal="8dp"
                    android:text="PRONTO"
                    android:textColor="#121212"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/bg_badge_gold"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Card: Analytics avanzado (Premium) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_card_dark"
                android:padding="16dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_crown"
                    android:background="@drawable/shape_circle_gold_outline"
                    android:padding="10dp"
                    app:tint="@color/gold_primary"
                    android:alpha="0.6" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Analytics avanzado"
                            android:textColor="#CCCCCC"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="18dp"
                            android:layout_marginStart="8dp"
                            android:paddingHorizontal="6dp"
                            android:text="PREMIUM"
                            android:textColor="#121212"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/bg_badge_gold" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Gráficas detalladas, predicciones y comparativas"
                        android:textColor="#555555"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.3" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="20dp"
                    android:paddingHorizontal="8dp"
                    android:text="PRONTO"
                    android:textColor="#121212"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/bg_badge_gold"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>