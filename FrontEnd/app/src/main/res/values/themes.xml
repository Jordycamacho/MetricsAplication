<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AppFit" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/gold_primary</item>
        <item name="colorPrimaryVariant">@color/gold_secondary</item>
        <item name="colorOnPrimary">@color/background_dark</item>
        <item name="colorSecondary">@color/gold_light</item>
        <item name="colorSecondaryVariant">@color/gold_secondary</item>
        <item name="colorOnSecondary">@color/background_dark</item>
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/surface_dark</item>
    </style>

    <style name="Theme.AppFit.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="CardView.AppFit" parent="CardView">
        <item name="cardBackgroundColor">@color/card_dark</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="FilterChip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/card_dark</item>
        <item name="chipStrokeColor">@color/gold_primary</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/text_primary_dark</item>
        <item name="checkedIcon">@null</item>
        <item name="checkedIconTint">@color/gold_primary</item>
        <item name="chipMinTouchTargetSize">0dp</item>
        <item name="chipCornerRadius">16dp</item>
    </style>

    <style name="GoldButton" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/gold_primary</item>
        <item name="android:textColor">@color/background_dark</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="OutlineButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/gold_primary</item>
        <item name="android:backgroundTint">@android:color/transparent</item>
        <item name="strokeColor">@color/gold_primary</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="ThemeOverlay.App.MaterialAlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_primary_dark</item>
        <item name="buttonBarPositiveButtonStyle">@style/GoldButton</item>
    </style>
    <!-- Añadir dentro de <resources> en res/values/styles.xml -->

    <style name="FormLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/gold_primary</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:layout_marginBottom">6dp</item>
    </style>

    <style name="FormField" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">20dp</item>
        <item name="boxBackgroundColor">@color/surface_dark</item>
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>
        <item name="boxStrokeColor">#333333</item>
        <item name="hintTextColor">#666666</item>
    </style>
</resources>