<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1E1E1E">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#1E1E1E"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="#78703F"
            app:title="Nuevo Set"
            app:titleTextColor="#FFFFFF" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#78703F"
        android:alpha="0.4" />

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:indeterminateTint="#78703F"
        android:visibility="gone" />

    <!-- Contenido scrollable -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- ── Sección: información del set ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="INFORMACIÓN DEL SET"
                android:textColor="#78703F"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />

            <!-- Posición + Tipo -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:boxBackgroundMode="outline"
                    app:boxBackgroundColor="#1E1E1E"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:boxStrokeColor="#333333"
                    app:hintTextColor="#B3B3B3"
                    android:hint="Posición">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_set_position"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="1"
                        android:textColor="#FFFFFF"
                        android:inputType="number"
                        android:paddingVertical="14dp" />

                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="TIPO"
                        android:textColor="#B3B3B3"
                        android:textSize="11sp"
                        android:layout_marginBottom="4dp" />

                    <Spinner
                        android:id="@+id/spinner_set_type"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:backgroundTint="#78703F" />

                </LinearLayout>

            </LinearLayout>

            <!-- Descanso + Sub-set -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:boxBackgroundMode="outline"
                    app:boxBackgroundColor="#1E1E1E"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:boxStrokeColor="#333333"
                    app:hintTextColor="#B3B3B3"
                    android:hint="Descanso (s)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_rest_after_set"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:inputType="number"
                        android:paddingVertical="14dp" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:boxBackgroundMode="outline"
                    app:boxBackgroundColor="#1E1E1E"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:boxStrokeColor="#333333"
                    app:hintTextColor="#B3B3B3"
                    android:hint="Sub-set">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_sub_set_number"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:inputType="number"
                        android:paddingVertical="14dp" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <!-- Grupo (drop sets, super sets) -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:boxBackgroundMode="outline"
                app:boxBackgroundColor="#1E1E1E"
                app:boxCornerRadiusTopStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusBottomEnd="10dp"
                app:boxStrokeColor="#333333"
                app:hintTextColor="#B3B3B3"
                android:hint="Grupo (ej: DROP_1, SUPER_A)">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_group_id"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:paddingVertical="14dp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── Sección: parámetros seleccionados ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PARÁMETROS"
                android:textColor="#78703F"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tv_no_selected_parameters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No hay parámetros añadidos"
                android:textColor="#B3B3B3"
                android:textSize="13sp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/layout_selected_parameters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="8dp">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_selected"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_parameter"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="+ Añadir parámetro"
                android:textColor="#78703F"
                app:strokeColor="#78703F"
                app:cornerRadius="10dp"
                android:layout_marginBottom="24dp" />

            <!-- ── Sección: seleccionar parámetros (oculta inicialmente) ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/layout_parameter_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:visibility="gone"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header panel -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="SELECCIONAR PARÁMETRO"
                            android:textColor="#78703F"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />

                        <ImageButton
                            android:id="@+id/btn_close_parameters"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_close"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:padding="4dp"
                            app:tint="#B3B3B3" />

                    </LinearLayout>

                    <!-- Búsqueda -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        app:boxBackgroundMode="outline"
                        app:boxBackgroundColor="#121212"
                        app:boxCornerRadiusTopStart="10dp"
                        app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp"
                        app:boxCornerRadiusBottomEnd="10dp"
                        app:boxStrokeColor="#333333"
                        app:startIconDrawable="@android:drawable/ic_menu_search"
                        app:startIconTint="#78703F"
                        android:hint="Buscar..."
                        app:hintTextColor="#666666">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_parameter_search"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#666666"
                            android:inputType="text"
                            android:imeOptions="actionSearch"
                            android:paddingVertical="10dp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Botón limpiar búsqueda (oculto por defecto) -->
                    <ImageButton
                        android:id="@+id/btn_clear_search"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:visibility="gone" />

                    <!-- Filtros -->
                    <com.google.android.material.chip.ChipGroup
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_all"
                            style="@style/FilterChip"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="Todos"
                            android:textSize="12sp"
                            android:checked="true" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_my"
                            style="@style/FilterChip"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="Míos"
                            android:textSize="12sp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_number"
                            style="@style/FilterChip"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="Número"
                            android:textSize="12sp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_integer"
                            style="@style/FilterChip"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="Entero"
                            android:textSize="12sp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_duration"
                            style="@style/FilterChip"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="Tiempo"
                            android:textSize="12sp" />

                    </com.google.android.material.chip.ChipGroup>

                    <TextView
                        android:id="@+id/tv_no_parameters"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Sin parámetros disponibles"
                        android:textColor="#B3B3B3"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:padding="16dp"
                        android:visibility="gone" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_parameters"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="true" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ── Botón guardar ── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_set"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="GUARDAR SET"
                android:textColor="#121212"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                app:backgroundTint="#78703F"
                app:cornerRadius="12dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>