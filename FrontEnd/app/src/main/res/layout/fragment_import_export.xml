<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_dark"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingHorizontal="4dp"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/gold_primary"
            app:title="Importar / Exportar"
            app:titleTextColor="#FFFFFF" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!-- Hero: no disponible en beta -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="36dp"
                android:paddingHorizontal="32dp">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_training"
                    app:tint="@color/gold_primary"
                    android:alpha="0.5" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Importar y Exportar"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="No disponible en la Beta"
                    android:textColor="@color/gold_primary"
                    android:textSize="13sp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Podrás mover tus rutinas, ejercicios, parámetros, deportes y packs entre dispositivos o compartirlos con otros usuarios."
                    android:textColor="#666666"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.4" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1E1E1E"
                android:layout_marginHorizontal="16dp" />

            <!-- ── EXPORTAR ────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EXPORTAR"
                android:textColor="@color/gold_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginStart="20dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp" />

            <!-- Exportar rutinas -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_card_dark"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/shape_circle_gold_outline"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_training"
                        app:tint="@color/gold_primary" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Exportar rutinas"
                        android:textColor="#CCCCCC"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Guarda tus rutinas en un archivo .json o compártelas con un enlace"
                        android:textColor="#555555"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.3" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="20dp"
                    android:paddingHorizontal="8dp"
                    android:text="STANDARD"
                    android:textColor="#121212"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/bg_badge_gold"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Exportar ejercicios -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_card_dark"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/shape_circle_gold_outline"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_training"
                        app:tint="@color/gold_primary" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Exportar ejercicios personalizados"
                        android:textColor="#CCCCCC"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Exporta los ejercicios que has creado para usarlos en otro dispositivo"
                        android:textColor="#555555"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.3" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="20dp"
                    android:paddingHorizontal="8dp"
                    android:text="STANDARD"
                    android:textColor="#121212"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/bg_badge_gold"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Exportar parámetros y deportes -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_card_dark"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/shape_circle_gold_outline"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_training"
                        app:tint="@color/gold_primary" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Exportar parámetros y deportes"
                        android:textColor="#CCCCCC"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Lleva tu configuración personalizada a cualquier dispositivo"
                        android:textColor="#555555"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.3" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="20dp"
                    android:paddingHorizontal="8dp"
                    android:text="STANDARD"
                    android:textColor="#121212"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/bg_badge_gold"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- ── IMPORTAR ────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IMPORTAR"
                android:textColor="@color/gold_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginStart="20dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp" />

            <!-- Importar desde archivo -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_card_dark"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/shape_circle_gold_outline"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_add"
                        app:tint="@color/gold_primary" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Importar desde archivo"
                        android:textColor="#CCCCCC"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Selecciona un archivo .json exportado previamente para restaurar tu contenido"
                        android:textColor="#555555"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.3" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="20dp"
                    android:paddingHorizontal="8dp"
                    android:text="STANDARD"
                    android:textColor="#121212"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/bg_badge_gold"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Importar desde enlace -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_card_dark"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/shape_circle_gold_outline"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="@color/gold_primary" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Importar desde enlace"
                        android:textColor="#CCCCCC"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Pega un enlace de rutina compartida por otro usuario para añadirla a tu cuenta"
                        android:textColor="#555555"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.3" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="20dp"
                    android:paddingHorizontal="8dp"
                    android:text="STANDARD"
                    android:textColor="#121212"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/bg_badge_gold"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- ── PACKS ───────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PACKS"
                android:textColor="@color/gold_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginStart="20dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp" />

            <!-- Crear pack -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_card_dark"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/shape_circle_gold_outline"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_add"
                        app:tint="@color/gold_primary" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Crear pack"
                            android:textColor="#CCCCCC"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="18dp"
                            android:layout_marginStart="8dp"
                            android:paddingHorizontal="6dp"
                            android:text="PREMIUM"
                            android:textColor="#121212"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/bg_badge_gold" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Agrupa rutinas, ejercicios y configuración en un pack distribuible"
                        android:textColor="#555555"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.3" />

                </LinearLayout>

            </LinearLayout>

            <!-- Vender pack en marketplace -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_card_dark"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/shape_circle_gold_outline"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_crown"
                        app:tint="@color/gold_primary" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Vender pack en marketplace"
                            android:textColor="#CCCCCC"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="18dp"
                            android:layout_marginStart="8dp"
                            android:paddingHorizontal="6dp"
                            android:text="PREMIUM"
                            android:textColor="#121212"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/bg_badge_gold" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Publica tu pack en el marketplace y gana dinero cuando otros usuarios lo compren"
                        android:textColor="#555555"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.3" />

                </LinearLayout>

            </LinearLayout>

            <!-- Compartir pack gratis -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_card_dark"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/shape_circle_gold_outline"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="@color/gold_primary" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Compartir pack gratis"
                            android:textColor="#CCCCCC"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="18dp"
                            android:layout_marginStart="8dp"
                            android:paddingHorizontal="6dp"
                            android:text="STANDARD"
                            android:textColor="#121212"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/bg_badge_gold" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Genera un enlace para que otros usuarios instalen tu pack sin coste"
                        android:textColor="#555555"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.3" />

                </LinearLayout>

            </LinearLayout>

            <!-- Nota beta -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_danger"
                android:padding="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_lock"
                    app:tint="#E53935"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Todas estas funciones estarán disponibles a partir de la versión 1.0. Durante la beta solo puedes explorar cómo funcionarán."
                    android:textColor="#E57373"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.4" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>