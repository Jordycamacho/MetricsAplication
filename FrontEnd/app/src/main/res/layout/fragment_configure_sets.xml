<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_dark">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:title="Configurar Sets"
            app:titleTextColor="@color/text_primary_dark" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Resumen de sets -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/card_dark">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Sets Configurados"
                        android:textColor="@color/gold_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_set_count"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Sets: 0"
                        android:textColor="@color/text_primary_dark"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tv_sets_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No hay sets configurados"
                        android:textColor="@color/text_secondary_dark"
                        android:textSize="12sp"
                        android:maxLines="10"
                        android:ellipsize="end" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Formulario para agregar set -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/card_dark">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Agregar Nuevo Set"
                        android:textColor="@color/gold_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <!-- Información básica -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <!-- Posición del set -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Posición"
                                android:textColor="@color/text_secondary_dark"
                                android:textSize="14sp" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:boxBackgroundMode="outline"
                                app:hintTextColor="@color/text_secondary_dark"
                                app:boxStrokeColor="@color/gold_primary"
                                app:boxStrokeWidth="1dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_set_position"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="Ej: 1"
                                    android:text="1"
                                    android:textColor="@color/text_primary_dark"
                                    android:inputType="number" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <!-- Tipo de set -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Tipo de Set"
                                android:textColor="@color/text_secondary_dark"
                                android:textSize="14sp" />

                            <Spinner
                                android:id="@+id/spinner_set_type"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:backgroundTint="@color/gold_primary" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Parámetros principales -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <!-- Repeticiones -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Repeticiones"
                                android:textColor="@color/text_secondary_dark"
                                android:textSize="14sp" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:boxBackgroundMode="outline"
                                app:hintTextColor="@color/text_secondary_dark"
                                app:boxStrokeColor="@color/gold_primary"
                                app:boxStrokeWidth="1dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_reps"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="Ej: 10"
                                    android:textColor="@color/text_primary_dark"
                                    android:inputType="number" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <!-- Peso -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Peso (kg)"
                                android:textColor="@color/text_secondary_dark"
                                android:textSize="14sp" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:boxBackgroundMode="outline"
                                app:hintTextColor="@color/text_secondary_dark"
                                app:boxStrokeColor="@color/gold_primary"
                                app:boxStrokeWidth="1dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_weight"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="Ej: 20"
                                    android:textColor="@color/text_primary_dark"
                                    android:inputType="numberDecimal" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Configuración avanzada -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardBackgroundColor="@color/surface_dark"
                        app:cardCornerRadius="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Configuración Avanzada"
                                android:textColor="@color/text_secondary_dark"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:padding="12dp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:paddingBottom="12dp">

                                <!-- Descanso después del set -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginEnd="8dp"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="Descanso (seg)"
                                        android:textColor="@color/text_secondary_dark"
                                        android:textSize="12sp" />

                                    <com.google.android.material.textfield.TextInputLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        app:boxBackgroundMode="outline"
                                        app:hintTextColor="@color/text_secondary_dark"
                                        app:boxStrokeColor="@color/gold_primary"
                                        app:boxStrokeWidth="1dp">

                                        <com.google.android.material.textfield.TextInputEditText
                                            android:id="@+id/et_rest_after_set"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:hint="60"
                                            android:textColor="@color/text_primary_dark"
                                            android:inputType="number" />
                                    </com.google.android.material.textfield.TextInputLayout>
                                </LinearLayout>

                                <!-- Sub-set number -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="Sub-set"
                                        android:textColor="@color/text_secondary_dark"
                                        android:textSize="12sp" />

                                    <com.google.android.material.textfield.TextInputLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        app:boxBackgroundMode="outline"
                                        app:hintTextColor="@color/text_secondary_dark"
                                        app:boxStrokeColor="@color/gold_primary"
                                        app:boxStrokeWidth="1dp">

                                        <com.google.android.material.textfield.TextInputEditText
                                            android:id="@+id/et_sub_set_number"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:hint="1"
                                            android:textColor="@color/text_primary_dark"
                                            android:inputType="number" />
                                    </com.google.android.material.textfield.TextInputLayout>
                                </LinearLayout>
                            </LinearLayout>

                            <!-- Group ID -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:paddingBottom="12dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Grupo (para drops, supersets)"
                                    android:textColor="@color/text_secondary_dark"
                                    android:textSize="12sp" />

                                <com.google.android.material.textfield.TextInputLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    app:boxBackgroundMode="outline"
                                    app:hintTextColor="@color/text_secondary_dark"
                                    app:boxStrokeColor="@color/gold_primary"
                                    app:boxStrokeWidth="1dp">

                                    <com.google.android.material.textfield.TextInputEditText
                                        android:id="@+id/et_group_id"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:hint="DROP_1, CLUSTER_A"
                                        android:textColor="@color/text_primary_dark" />
                                </com.google.android.material.textfield.TextInputLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Sección de Parámetros del Set -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="@color/card_dark">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <!-- Header colapsable -->
                            <LinearLayout
                                android:id="@+id/layout_parameter_header"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:clickable="true"
                                android:focusable="true"
                                android:paddingBottom="12dp">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Parámetros del Set"
                                    android:textColor="@color/gold_primary"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                                <ImageView
                                    android:id="@+id/iv_parameter_arrow"
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/ic_arrow_down"
                                    app:tint="@color/text_secondary_dark" />
                            </LinearLayout>



                            <!-- Parámetros seleccionados -->
                            <TextView
                                android:id="@+id/tv_no_selected_parameters"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="No hay parámetros seleccionados"
                                android:textColor="@color/text_secondary_dark"
                                android:textSize="14sp"
                                android:textAlignment="center"
                                android:padding="16dp" />

                            <LinearLayout
                                android:id="@+id/layout_selected_parameters"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:visibility="gone">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Parámetros seleccionados:"
                                    android:textColor="@color/text_primary_dark"
                                    android:textSize="14sp"
                                    android:layout_marginBottom="8dp" />

                                <com.google.android.material.chip.ChipGroup
                                    android:id="@+id/chip_group_selected"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="12dp" />
                            </LinearLayout>

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Botones de acción -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginTop="16dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_add_set"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:text="Crear Set"
                            android:textColor="@color/background_dark"
                            app:backgroundTint="@color/gold_primary"
                            app:cornerRadius="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_add_to_set"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="+ Agregar Parámetros"
                            android:textColor="@color/gold_primary"
                            app:backgroundTint="@android:color/transparent"
                            app:cornerRadius="8dp"
                            app:strokeColor="@color/gold_primary"
                            app:strokeWidth="1dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Sección para agregar parámetros (inicialmente oculta) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/layout_parameter_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/card_dark">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header con botón de cerrar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Agregar Parámetros al Set"
                            android:textColor="@color/gold_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <ImageButton
                            android:id="@+id/btn_close_parameters"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_close"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            app:tint="@color/text_secondary_dark" />
                    </LinearLayout>

                    <!-- Buscador de parámetros -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@color/surface_dark">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="8dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_search"
                                android:layout_marginStart="8dp"
                                android:layout_marginEnd="8dp"
                                app:tint="@color/text_secondary_dark" />

                            <EditText
                                android:id="@+id/et_parameter_search"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:hint="Buscar parámetros..."
                                android:textColor="@color/text_primary_dark"
                                android:textColorHint="@color/text_secondary_dark"
                                android:background="@null"
                                android:imeOptions="actionSearch"
                                android:singleLine="true"
                                android:maxLines="1" />

                            <ImageButton
                                android:id="@+id/btn_clear_search"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_close"
                                android:layout_marginStart="8dp"
                                android:layout_marginEnd="8dp"
                                android:visibility="gone"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                app:tint="@color/text_secondary_dark" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Filtros rápidos -->
                    <com.google.android.material.chip.ChipGroup
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:singleSelection="false">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_all"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Todos"
                            app:chipBackgroundColor="@color/gold_primary"
                            app:chipStrokeColor="@color/gold_primary"
                            app:chipStrokeWidth="1dp"
                            app:checkedIconVisible="false" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_my"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mis parámetros"
                            app:chipBackgroundColor="@color/gold_primary"
                            app:chipStrokeColor="@color/gold_primary"
                            app:chipStrokeWidth="1dp"
                            app:checkedIconVisible="false" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_number"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Numéricos"
                            app:chipBackgroundColor="@color/gold_primary"
                            app:chipStrokeColor="@color/gold_primary"
                            app:chipStrokeWidth="1dp"
                            app:checkedIconVisible="false" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_integer"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Enteros"
                            app:chipBackgroundColor="@color/gold_primary"
                            app:chipStrokeColor="@color/gold_primary"
                            app:chipStrokeWidth="1dp"
                            app:checkedIconVisible="false" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_duration"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Duración"
                            app:chipBackgroundColor="@color/gold_primary"
                            app:chipStrokeColor="@color/gold_primary"
                            app:chipStrokeWidth="1dp"
                            app:checkedIconVisible="false" />
                    </com.google.android.material.chip.ChipGroup>

                    <!-- Lista de parámetros -->
                    <TextView
                        android:id="@+id/tv_no_parameters"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No hay parámetros disponibles"
                        android:textColor="@color/text_secondary_dark"
                        android:textSize="14sp"
                        android:textAlignment="center"
                        android:padding="16dp"
                        android:visibility="gone" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_parameters"
                        android:layout_width="match_parent"
                        android:layout_height="300dp"
                        android:layout_marginBottom="12dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Botones de acción final -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save_all"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Guardar y Salir"
                    android:textColor="@color/background_dark"
                    app:backgroundTint="@color/gold_primary"
                    app:cornerRadius="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_clear_all"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Eliminar Todos"
                    android:textColor="@color/red"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="8dp"
                    app:strokeColor="@color/red"
                    app:strokeWidth="1dp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>