<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Encabezado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Mis Rutinas"
                android:textSize="24sp"
                android:textColor="@color/gold_primary"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btn_create_routine"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_launcher_foreground"
                android:contentDescription="Crear nueva rutina" />
        </LinearLayout>

        <!-- Barra de búsqueda -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/card_dark">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_launcher_foreground"
                    android:layout_marginEnd="8dp" />

                <EditText
                    android:id="@+id/et_search_routines"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Buscar rutinas..."
                    android:textColor="@color/text_primary_dark"
                    android:textColorHint="@color/text_secondary_dark"
                    android:background="@null"
                    android:imeOptions="actionSearch"
                    android:singleLine="true"
                    android:minHeight="48dp"
                    android:padding="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Filtros por categoría -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Todas"
                    app:chipBackgroundColor="@color/gold_primary"
                    style="@style/FilterChip" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_cardio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cardio"
                    style="@style/FilterChip" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_gym"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gym"
                    style="@style/FilterChip" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_boxeo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Boxeo"
                    style="@style/FilterChip" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_fuerza"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fuerza"
                    style="@style/FilterChip" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_technica"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Técnica"
                    style="@style/FilterChip" />
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Lista de rutinas -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Rutina 1: Gym - Fuerza -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_dark">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Encabezado de la rutina -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Rutina de Gym - Fuerza"
                            android:textSize="18sp"
                            android:textColor="@color/text_primary_dark"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="60 min"
                            android:textSize="14sp"
                            android:textColor="@color/gold_primary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Detalles de la rutina -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="8 ejercicios"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary_dark" />

                        <View
                            android:layout_width="1dp"
                            android:layout_height="12dp"
                            android:background="@color/divider_dark"
                            android:layout_marginStart="12dp"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fuerza"
                            android:textSize="14sp"
                            android:textColor="@color/gold_primary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Descripción -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Rutina enfocada en desarrollo de fuerza con ejercicios compuestos"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary_dark"
                        android:layout_marginBottom="16dp" />

                    <!-- Botones de acción -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <Button
                            android:id="@+id/btn_start_workout1"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="Iniciar"
                            style="@style/GoldButton"
                            android:layout_marginEnd="8dp" />

                        <Button
                            android:id="@+id/btn_edit1"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="Editar"
                            style="@style/OutlineButton" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Rutina 2: Boxeo - Técnica -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_dark">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Encabezado de la rutina -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Boxeo - Técnica"
                            android:textSize="18sp"
                            android:textColor="@color/text_primary_dark"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="45 min"
                            android:textSize="14sp"
                            android:textColor="@color/gold_primary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Detalles de la rutina -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="6 ejercicios"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary_dark" />

                        <View
                            android:layout_width="1dp"
                            android:layout_height="12dp"
                            android:background="@color/divider_dark"
                            android:layout_marginStart="12dp"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Técnica"
                            android:textSize="14sp"
                            android:textColor="@color/gold_primary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Descripción -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Trabajo de técnica de boxeo con combinaciones y footwork"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary_dark"
                        android:layout_marginBottom="16dp" />

                    <!-- Botones de acción -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <Button
                            android:id="@+id/btn_start_workout2"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="Iniciar"
                            style="@style/GoldButton"
                            android:layout_marginEnd="8dp" />

                        <Button
                            android:id="@+id/btn_edit2"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="Editar"
                            style="@style/OutlineButton" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Espacio al final para scroll -->
        <View
            android:layout_width="match_parent"
            android:layout_height="40dp" />

    </LinearLayout>
</ScrollView>