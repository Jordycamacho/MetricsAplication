<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- Todo el contenido vertical aquí dentro -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header: toolbar + búsqueda + chips -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:paddingBottom="12dp">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="#1E1E1E"
                app:navigationIcon="@drawable/ic_arrow_back"
                app:navigationIconTint="#78703F"
                app:title="Agregar Ejercicio"
                app:titleTextColor="#FFFFFF" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp"
                app:boxBackgroundMode="outline"
                app:boxBackgroundColor="#121212"
                app:boxCornerRadiusTopStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusBottomEnd="10dp"
                app:boxStrokeColor="#333333"
                app:boxStrokeWidth="1dp"
                app:startIconDrawable="@android:drawable/ic_menu_search"
                app:startIconTint="#78703F"
                android:hint="Buscar ejercicios..."
                app:hintTextColor="#666666">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_search"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#666666"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:paddingVertical="12dp" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.chip.ChipGroup
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_all"
                    style="@style/FilterChip"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Todos"
                    android:checked="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_my"
                    style="@style/FilterChip"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Mis ejercicios" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_available"
                    style="@style/FilterChip"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Disponibles" />

            </com.google.android.material.chip.ChipGroup>

        </LinearLayout>

        <!-- Separador dorado -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#78703F"
            android:alpha="0.4" />

        <!-- Configuración sesión / día -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CONFIGURACIÓN"
                android:textColor="#78703F"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp" />

            <RadioGroup
                android:id="@+id/rg_organization"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <RadioButton
                    android:id="@+id/rb_by_session"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Por Sesión"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:buttonTint="#78703F" />

                <RadioButton
                    android:id="@+id/rb_by_day"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Por Día"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:buttonTint="#78703F" />

            </RadioGroup>

            <LinearLayout
                android:id="@+id/layout_session"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SESIÓN"
                    android:textColor="#B3B3B3"
                    android:textSize="12sp" />

                <Spinner
                    android:id="@+id/spinner_session"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="2"
                    android:backgroundTint="#78703F" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_day"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="DÍA"
                    android:textColor="#B3B3B3"
                    android:textSize="12sp" />

                <Spinner
                    android:id="@+id/spinner_day"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="2"
                    android:backgroundTint="#78703F" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:boxBackgroundMode="outline"
                    app:boxBackgroundColor="#121212"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:boxStrokeColor="#333333"
                    app:hintTextColor="#B3B3B3"
                    android:hint="Orden">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_session_order"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:inputType="number"
                        android:paddingVertical="12dp" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:boxBackgroundMode="outline"
                    app:boxBackgroundColor="#121212"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:boxStrokeColor="#333333"
                    app:hintTextColor="#B3B3B3"
                    android:hint="Descanso (s)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_rest_after"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:inputType="number"
                        android:paddingVertical="12dp" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Separador dorado -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#78703F"
            android:alpha="0.4" />

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:indeterminateTint="#78703F"
            android:visibility="gone" />

        <!-- Lista: ocupa el espacio restante -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_exercises"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="96dp"
            android:clipToPadding="false"
            android:overScrollMode="never" />

    </LinearLayout>

    <!-- FAB flotante sobre todo el contenido — FUERA del LinearLayout -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/btn_add_exercise"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        android:text="Añadir ejercicio"
        android:textColor="#121212"
        app:icon="@drawable/ic_add"
        app:iconTint="#121212"
        app:backgroundTint="#78703F"
        android:visibility="gone" />

    <!-- Referencia oculta para btn_clear_search -->
    <View
        android:id="@+id/btn_clear_search"
        android:layout_width="0dp"
        android:layout_height="0dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>