<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/card_dark"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#2A2A2A"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Nombre + última vez -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tv_routine_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nombre de la rutina"
                android:textSize="16sp"
                android:textColor="@color/text_primary_dark"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1" />

            <TextView
                android:id="@+id/tv_last_used"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hoy"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#121212"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:background="@drawable/badge_predefined"
                android:layout_marginStart="10dp" />

        </LinearLayout>

        <!-- Deporte -->
        <TextView
            android:id="@+id/tv_sport_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Deporte"
            android:textSize="12sp"
            android:textColor="@color/gold_primary"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Descripción -->
        <TextView
            android:id="@+id/tv_routine_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Descripción de la rutina"
            android:textSize="13sp"
            android:textColor="@color/text_secondary_dark"
            android:layout_marginBottom="6dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:lineSpacingMultiplier="1.3" />

        <!-- Ejercicios count -->
        <TextView
            android:id="@+id/tv_exercise_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 ejercicios"
            android:textSize="12sp"
            android:textColor="@color/text_secondary_dark"
            android:layout_marginBottom="12dp" />

        <!-- Separador -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#252525"
            android:layout_marginBottom="12dp" />

        <!-- Botones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- INICIAR (principal, relleno dorado) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_start_workout"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Iniciar"
                android:textColor="#121212"
                android:textSize="13sp"
                android:textStyle="bold"
                app:backgroundTint="@color/gold_primary"
                app:cornerRadius="10dp"
                android:elevation="0dp"
                android:layout_marginEnd="8dp" />

            <!-- EDITAR (contorno) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_edit"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Editar"
                android:textColor="@color/gold_primary"
                android:textSize="13sp"
                app:strokeColor="@color/gold_primary"
                app:strokeWidth="1dp"
                app:cornerRadius="10dp"
                android:layout_marginEnd="8dp" />

            <!-- AGREGAR SET (icono) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_exercises"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="+"
                android:textColor="@color/gold_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingHorizontal="0dp"
                app:strokeColor="@color/gold_primary"
                app:strokeWidth="1dp"
                app:cornerRadius="10dp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>