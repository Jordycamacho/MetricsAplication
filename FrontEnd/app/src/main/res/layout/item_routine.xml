<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/card_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Encabezado con nombre y estado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tv_routine_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nombre de rutina"
                android:textSize="18sp"
                android:textColor="@color/text_primary_dark"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1" />

            <TextView
                android:id="@+id/tv_last_used"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hoy"
                android:textSize="12sp"
                android:textColor="@color/text_secondary_dark"
                android:textStyle="italic"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:background="@drawable/badge_predefined"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Información rápida -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tv_exercise_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="8 ejercicios"
                android:textSize="13sp"
                android:textColor="@color/text_secondary_dark"
                android:drawableStart="@drawable/ic_training"
                android:drawablePadding="4dp"
                android:drawableTint="@color/gold_primary" />

            <View
                android:layout_width="1dp"
                android:layout_height="12dp"
                android:background="@color/divider_dark"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/tv_sport_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Deporte"
                android:textSize="13sp"
                android:textColor="@color/gold_primary"
                android:textStyle="bold"
                android:drawableStart="@drawable/ic_metrics"
                android:drawablePadding="4dp"
                android:drawableTint="@color/gold_primary" />
        </LinearLayout>

        <!-- Descripción -->
        <TextView
            android:id="@+id/tv_routine_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Descripción de la rutina..."
            android:textSize="14sp"
            android:textColor="@color/text_secondary_dark"
            android:layout_marginBottom="16dp"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- Botones de acción -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3">

            <!-- Botón INICIAR (principal) -->
            <TextView
                android:id="@+id/btn_start_workout"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1.2"
                android:text="INICIAR"
                android:gravity="center"
                android:textColor="@color/background_dark"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/button_gold_background"
                android:layout_marginEnd="4dp"
                android:drawableStart="@drawable/ic_play"
                android:drawablePadding="4dp"
                android:drawableTint="@color/background_dark" />

            <!-- Botón EDITAR -->
            <TextView
                android:id="@+id/btn_edit"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="0.9"
                android:text="EDITAR"
                android:gravity="center"
                android:textColor="@color/gold_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/button_outline_gold"
                android:layout_marginEnd="4dp"
                android:drawableStart="@drawable/ic_edit"
                android:drawablePadding="4dp"
                android:drawableTint="@color/gold_primary" />

            <!-- Botón AGREGAR -->
            <TextView
                android:id="@+id/btn_add_exercises"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="0.9"
                android:text="+"
                android:gravity="center"
                android:textColor="@color/gold_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/button_outline_gold"
                android:drawableStart="@drawable/ic_add"
                android:drawablePadding="4dp"
                android:drawableTint="@color/gold_primary" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>