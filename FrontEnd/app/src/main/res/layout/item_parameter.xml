<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/card_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Fila superior: Nombre y Tipo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tv_parameter_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nombre del Parámetro"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary_dark" />

            <TextView
                android:id="@+id/tv_parameter_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TIPO"
                android:textSize="12sp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:background="@drawable/ic_arrow_right"
                android:textColor="@color/white"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Fila media: Unidad y Categoría -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tv_parameter_unit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="(kg)"
                android:textSize="14sp"
                android:textColor="@color/gold_primary"
                android:textStyle="bold" />

            <View
                android:layout_width="1dp"
                android:layout_height="12dp"
                android:background="@color/divider_dark"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/tv_parameter_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Categoría"
                android:textSize="14sp"
                android:textColor="@color/text_secondary_dark" />
        </LinearLayout>

        <!-- Separador -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_dark"
            android:layout_marginBottom="12dp" />

        <!-- Fila inferior: Botones de acción -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <TextView
                android:id="@+id/btn_edit_parameter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EDITAR"
                android:textSize="14sp"
                android:textColor="@color/gold_primary"
                android:textStyle="bold"
                android:paddingVertical="8dp"
                android:paddingHorizontal="16dp"
                android:background="@drawable/button_edit_background" />

            <TextView
                android:id="@+id/btn_delete_parameter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ELIMINAR"
                android:textSize="14sp"
                android:textColor="@color/red"
                android:textStyle="bold"
                android:paddingVertical="8dp"
                android:paddingHorizontal="16dp"
                android:background="@drawable/button_delete_background"
                android:layout_marginStart="8dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>