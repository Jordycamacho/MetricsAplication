<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Encabezado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_launcher_foreground"
                android:contentDescription="Volver" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Crear Nueva Rutina"
                android:textSize="24sp"
                android:textColor="@color/gold_primary"
                android:textStyle="bold"
                android:gravity="center" />
        </LinearLayout>

        <!-- Formulario de creación -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card_dark">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Nombre de la rutina -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nombre de la rutina"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary_dark"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/et_routine_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ej: Rutina de fuerza"
                    android:textColor="@color/text_primary_dark"
                    android:textColorHint="@color/text_secondary_dark"
                    android:backgroundTint="@color/gold_primary"
                    android:layout_marginBottom="48dp" />

                <!-- Selección de deporte -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Seleccionar deporte"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary_dark"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinner_sports"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:backgroundTint="@color/gold_primary"
                    android:layout_marginBottom="16dp" />

                <!-- Días de la semana -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Días de la semana"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary_dark"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="7">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="L"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary_dark"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="M"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary_dark"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="X"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary_dark"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="J"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary_dark"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="V"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary_dark"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="S"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary_dark"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="D"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary_dark"
                        android:gravity="center" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="7"
                    android:layout_marginBottom="16dp">

                    <CheckBox
                        android:id="@+id/cb_monday"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:buttonTint="@color/gold_primary"
                        android:gravity="center" />

                    <CheckBox
                        android:id="@+id/cb_tuesday"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:buttonTint="@color/gold_primary"
                        android:gravity="center" />

                    <CheckBox
                        android:id="@+id/cb_wednesday"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:buttonTint="@color/gold_primary"
                        android:gravity="center" />

                    <CheckBox
                        android:id="@+id/cb_thursday"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:buttonTint="@color/gold_primary"
                        android:gravity="center" />

                    <CheckBox
                        android:id="@+id/cb_friday"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:buttonTint="@color/gold_primary"
                        android:gravity="center" />

                    <CheckBox
                        android:id="@+id/cb_saturday"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:buttonTint="@color/gold_primary"
                        android:gravity="center" />

                    <CheckBox
                        android:id="@+id/cb_sunday"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:buttonTint="@color/gold_primary"
                        android:gravity="center" />
                </LinearLayout>

                <!-- Descripción -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Descripción (opcional)"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary_dark"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/et_routine_description"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:gravity="top"
                    android:hint="Describe el propósito de esta rutina..."
                    android:textColor="@color/text_primary_dark"
                    android:textColorHint="@color/text_secondary_dark"
                    android:backgroundTint="@color/gold_primary"
                    android:inputType="textMultiLine" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Botón de crear -->
        <Button
            android:id="@+id/btn_create_routine"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Crear Rutina"
            style="@style/GoldButton" />

    </LinearLayout>
</ScrollView>