<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#1E1E1E"
        app:navigationIcon="@drawable/ic_arrow_right"
        app:titleTextColor="#FFFFFF"
        app:title="Editar Categoría"
        app:navigationIconTint="#78703F" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#78703F"
        android:alpha="0.4" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="32dp">

            <!-- Header info con usos -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1A78703F"
                android:padding="14dp"
                android:layout_marginBottom="24dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="36dp"
                    android:background="#78703F"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Categoría Personal"
                        android:textColor="#78703F"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tv_usage_info"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Solo visible para ti"
                        android:textColor="#B3B3B3"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Nombre -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NOMBRE"
                android:textColor="#78703F"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:boxBackgroundMode="outline"
                app:boxBackgroundColor="#1E1E1E"
                app:boxCornerRadiusTopStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusBottomEnd="10dp"
                app:hintTextColor="#B3B3B3"
                app:boxStrokeColor="#333333"
                app:boxStrokeWidth="1dp"
                android:hint="Nombre de la categoría">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:inputType="textCapSentences"
                    android:maxLength="100"
                    android:paddingVertical="14dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Deporte -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DEPORTE"
                android:textColor="#78703F"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                app:boxBackgroundColor="#1E1E1E"
                app:boxCornerRadiusTopStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusBottomEnd="10dp"
                app:hintTextColor="#B3B3B3"
                app:boxStrokeColor="#333333"
                app:boxStrokeWidth="1dp"
                android:hint="Sin deporte específico">

                <AutoCompleteTextView
                    android:id="@+id/spinner_sports"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:inputType="none"
                    android:focusable="true"
                    android:focusableInTouchMode="false"
                    android:paddingVertical="14dp"
                    android:paddingHorizontal="14dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Botón guardar -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="GUARDAR CAMBIOS"
                android:textColor="#121212"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                app:backgroundTint="#78703F"
                app:cornerRadius="12dp"
                android:elevation="0dp"
                android:layout_marginBottom="12dp" />

            <!-- Botón eliminar -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="ELIMINAR CATEGORÍA"
                android:textColor="#E41D1D"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                app:backgroundTint="#1AE41D1D"
                app:strokeColor="#E41D1D"
                app:strokeWidth="1dp"
                app:cornerRadius="12dp"
                android:elevation="0dp" />

            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                android:indeterminateTint="#78703F" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>