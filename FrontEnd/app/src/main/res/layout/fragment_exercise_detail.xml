<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface_dark"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:titleTextColor="@color/text_primary_dark" />

        <!-- Contenedor de contenido -->
        <LinearLayout
            android:id="@+id/content_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp">

            <!-- Tarjeta de información principal -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_dark"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Nombre y tipo -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:id="@+id/tv_exercise_name"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Nombre del ejercicio"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary_dark" />

                        <TextView
                            android:id="@+id/tv_exercise_type"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TIPO"
                            android:textSize="12sp"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"
                            android:background="@drawable/badge_predefined"
                            android:textColor="@color/white"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Descripción -->
                    <TextView
                        android:id="@+id/tv_exercise_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Descripción del ejercicio..."
                        android:textSize="16sp"
                        android:textColor="@color/text_secondary_dark"
                        android:layout_marginBottom="16dp" />

                    <!-- Separador -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider_dark"
                        android:layout_marginBottom="16dp" />

                    <!-- Información básica -->
                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="4"
                        android:layout_marginBottom="16dp">

                        <!-- Deporte -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Deporte:"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary_dark"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tv_sport"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gimnasio"
                            android:textSize="14sp"
                            android:textColor="@color/gold_primary"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />

                        <!-- Creador -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Creado por:"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary_dark"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tv_creator"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Usuario"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary_dark"
                            android:layout_marginBottom="8dp" />

                        <!-- Visibilidad -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Visibilidad:"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary_dark"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tv_visibility"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PERSONAL"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/gold_primary"
                            android:layout_marginBottom="8dp" />

                        <!-- Estado -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Estado:"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary_dark"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tv_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ACTIVO"
                            android:textSize="14sp"
                            android:textColor="@color/gold_primary"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />
                    </GridLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Tarjeta de categorías -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_dark"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📂 Categorías"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary_dark"
                        android:layout_marginBottom="12dp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_categories"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleLine="false"
                        app:singleSelection="false" />

                    <TextView
                        android:id="@+id/tv_no_categories"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Sin categorías asignadas"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary_dark"
                        android:gravity="center"
                        android:padding="16dp"
                        android:visibility="gone" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Tarjeta de parámetros -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_dark"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="⚙️ Parámetros Soportados"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary_dark"
                        android:layout_marginBottom="12dp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_parameters"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleLine="false"
                        app:singleSelection="false" />

                    <TextView
                        android:id="@+id/tv_no_parameters"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Sin parámetros configurados"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary_dark"
                        android:gravity="center"
                        android:padding="16dp"
                        android:visibility="gone" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Tarjeta de estadísticas -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_dark"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📊 Estadísticas"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary_dark"
                        android:layout_marginBottom="12dp" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="2">

                        <!-- Uso -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Veces usado:"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary_dark"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tv_usage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary_dark"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />

                        <!-- Rating -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Calificación:"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary_dark"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tv_rating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0 ⭐"
                            android:textSize="14sp"
                            android:textColor="@color/gold_primary"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />
                    </GridLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Tarjeta de fechas -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_dark"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📅 Fechas"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary_dark"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_created_at"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Creado: --/--/---- --:--"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary_dark"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tv_updated_at"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Actualizado: --/--/---- --:--"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary_dark"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tv_last_used"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Último uso: Nunca"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary_dark" />

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Botones de acción -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="32dp">

                <Button
                    android:id="@+id/btn_edit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="EDITAR"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/gold_primary"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btn_toggle_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="DESACTIVAR"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/blue_500"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp" />
            </LinearLayout>

            <!-- Botón de eliminar (separado) -->
            <Button
                android:id="@+id/btn_delete"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ELIMINAR EJERCICIO"
                android:textColor="@color/white"
                android:backgroundTint="@color/red" />

        </LinearLayout>

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="32dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>