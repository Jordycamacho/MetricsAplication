<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_dark">

    <!-- Toolbar fijo arriba -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_dark"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/gold_primary"
        app:titleTextColor="@color/text_primary_dark"
        app:title="Detalle del ejercicio" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/gold_primary"
        android:alpha="0.4" />

    <!-- ProgressBar superpuesto -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="48dp"
        android:indeterminateTint="@color/gold_primary"
        android:visibility="gone" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never"
        android:fillViewport="false">

        <LinearLayout
            android:id="@+id/content_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="32dp">

            <!-- CARD: Información principal -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#2A2A2A"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Nombre + badge tipo -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:id="@+id/tv_exercise_name"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Nombre del ejercicio"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary_dark" />

                        <TextView
                            android:id="@+id/tv_exercise_type"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TIPO"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#121212"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:background="@drawable/badge_predefined"
                            android:letterSpacing="0.05" />

                    </LinearLayout>

                    <!-- Descripción -->
                    <TextView
                        android:id="@+id/tv_exercise_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Sin descripción"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary_dark"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_marginBottom="14dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#252525"
                        android:layout_marginBottom="14dp" />

                    <!-- Deporte -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Deporte"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary_dark" />

                        <TextView
                            android:id="@+id/tv_sport"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/gold_primary" />

                    </LinearLayout>

                    <!-- Creador -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Creado por"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary_dark" />

                        <TextView
                            android:id="@+id/tv_creator"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary_dark" />

                    </LinearLayout>

                    <!-- Visibilidad -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Visibilidad"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary_dark" />

                        <TextView
                            android:id="@+id/tv_visibility"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Personal"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary_dark" />

                    </LinearLayout>

                    <!-- Estado -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Estado"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary_dark" />

                        <TextView
                            android:id="@+id/tv_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Activo"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/gold_primary" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CARD: Categorías -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#2A2A2A"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="16dp"
                            android:background="@color/gold_primary"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Categorías"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary_dark" />

                    </LinearLayout>

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_categories"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleLine="false"
                        app:singleSelection="false" />

                    <TextView
                        android:id="@+id/tv_no_categories"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Sin categorías asignadas"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary_dark"
                        android:gravity="center"
                        android:paddingVertical="8dp"
                        android:visibility="gone" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CARD: Parámetros -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#2A2A2A"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="16dp"
                            android:background="@color/gold_primary"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Parámetros"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary_dark" />

                    </LinearLayout>

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_parameters"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleLine="false"
                        app:singleSelection="false" />

                    <TextView
                        android:id="@+id/tv_no_parameters"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Sin parámetros configurados"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary_dark"
                        android:gravity="center"
                        android:paddingVertical="8dp"
                        android:visibility="gone" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CARD: Estadísticas + Fechas (unificadas) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#2A2A2A"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="16dp"
                            android:background="@color/gold_primary"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Estadísticas"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary_dark" />

                    </LinearLayout>

                    <!-- Stats en fila -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="14dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tv_usage"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="@color/gold_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Usos"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary_dark"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="40dp"
                            android:background="#2A2A2A" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tv_rating"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.0"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="@color/gold_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Valoración"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary_dark"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#252525"
                        android:layout_marginBottom="12dp" />

                    <!-- Fechas -->
                    <TextView
                        android:id="@+id/tv_created_at"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Creado: —"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary_dark"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tv_updated_at"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Actualizado: —"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary_dark"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tv_last_used"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Último uso: Nunca"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary_dark" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Botones de acción -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_edit"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Editar"
                    android:textColor="#121212"
                    android:textStyle="bold"
                    app:backgroundTint="@color/gold_primary"
                    app:cornerRadius="12dp"
                    android:elevation="0dp"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_toggle_status"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Pausar"
                    android:textColor="@color/gold_primary"
                    android:textStyle="bold"
                    app:strokeColor="@color/gold_primary"
                    app:strokeWidth="1dp"
                    app:cornerRadius="12dp" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Eliminar ejercicio"
                android:textColor="@color/red"
                android:textStyle="bold"
                app:strokeColor="@color/red"
                app:strokeWidth="1dp"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/badw_ssdadaave"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="CREAR EJERCICIO"
                android:textColor="#121212"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                app:backgroundTint="@color/gold_primary"
                app:cornerRadius="12dp"
                android:elevation="0dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/badw_ssddadaave"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="CREAR EJERCICIO"
                android:textColor="#121212"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                app:backgroundTint="@color/gold_primary"
                app:cornerRadius="12dp"
                android:elevation="0dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>