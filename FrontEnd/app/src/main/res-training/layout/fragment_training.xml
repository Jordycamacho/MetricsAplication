<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:paddingHorizontal="16dp"
    android:paddingVertical="20dp">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Centro de Entrenamiento"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gestiona tus rutinas, ejercicios y parámetros"
            android:textSize="13sp"
            android:textColor="#B3B3B3"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- SECCIÓN 1: NÚCLEO (Rutinas, Deportes, Ejercicios) -->
            <!-- ═══════════════════════════════════════════════════════════════ -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NÚCLEO"
                android:textSize="12sp"
                android:textColor="#78703F"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- Rutinas -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_routines"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="#78703F"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rutinas"
                            android:textSize="16sp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Crea y gestiona tus rutinas"
                            android:textSize="12sp"
                            android:textColor="#B3B3B3"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_training"
                        android:scaleType="centerInside"
                        app:tint="#78703F" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Deportes -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_sports"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="#78703F"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Deportes"
                            android:textSize="16sp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Deportes personalizados"
                            android:textSize="12sp"
                            android:textColor="#B3B3B3"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_sport_24"
                        android:scaleType="centerInside"
                        app:tint="#78703F" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Ejercicios -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_exercises"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="#78703F"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ejercicios"
                            android:textSize="16sp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Biblioteca de ejercicios"
                            android:textSize="12sp"
                            android:textColor="#B3B3B3"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_exercise_24"
                        android:scaleType="centerInside"
                        app:tint="#78703F" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- SECCIÓN 2: CONFIGURACIÓN (Parámetros, Marketplace) -->
            <!-- ═══════════════════════════════════════════════════════════════ -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONFIGURACIÓN"
                android:textSize="12sp"
                android:textColor="#78703F"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- Parámetros -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_parameters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="#78703F"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Parámetros"
                            android:textSize="16sp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Métricas personalizadas"
                            android:textSize="12sp"
                            android:textColor="#B3B3B3"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_parameter_24"
                        android:scaleType="centerInside"
                        app:tint="#78703F" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Marketplace -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_marketplace"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#1A78703F"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="#78703F"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Marketplace"
                            android:textSize="16sp"
                            android:textColor="#78703F"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Crea y comparte paquetes"
                            android:textSize="12sp"
                            android:textColor="#B3B3B3"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_shopping_bag"
                        android:scaleType="centerInside"
                        app:tint="#78703F" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Importar/Exportar -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_import_export"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="#78703F"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Importar/Exportar"
                            android:textSize="16sp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sincroniza tus datos"
                            android:textSize="12sp"
                            android:textColor="#B3B3B3"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_import_24"
                        android:scaleType="centerInside"
                        app:tint="#78703F" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- SECCIÓN 3: UTILIDADES (Categorías) -->
            <!-- ═══════════════════════════════════════════════════════════════ -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UTILIDADES"
                android:textSize="12sp"
                android:textColor="#78703F"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- Categorías -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_categories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="#78703F"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Categorías"
                            android:textSize="16sp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Organiza tus ejercicios"
                            android:textSize="12sp"
                            android:textColor="#B3B3B3"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_category_24"
                        android:scaleType="centerInside"
                        app:tint="#78703F" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>